{
  "name": "file-batch-approval",
  "description": "【教学模板 ③】智能文件审批管道 — 文件扫描→条件筛选→逐项审批（条件推荐）→归档通知。演示 Cursor 游标迭代、approval_conditions 条件推荐、runCondition 分支。",
  "params": {
    "data_dir": "C:\\Users\\haozi\\AppData\\Local\\Temp\\wf-approval-batch",
    "file_pattern": "doc-*.txt",
    "approval_timeout_ms": 5
  },
  "steps": [
    {
      "id": "step_1",
      "type": "file",
      "label": "1.准备测试文件集",
      "config": {},
      "actions": [
        {
          "id": "a1_1",
          "type": "write",
          "label": "创建合规报告Q1",
          "params": {
            "path": "{{params.data_dir}}/合规报告-Q1.txt",
            "content": "合规报告-Q1\n需审批项: 3\n风险等级: 低"
          }
        },
        {
          "id": "a1_2",
          "type": "write",
          "label": "创建合规报告Q2",
          "params": {
            "path": "{{params.data_dir}}/合规报告-Q2.txt",
            "content": "合规报告-Q2\n需审批项: 1\n风险等级: 低"
          }
        },
        {
          "id": "a1_3",
          "type": "write",
          "label": "创建风险评估Q3",
          "params": {
            "path": "{{params.data_dir}}/风险评估-Q3.txt",
            "content": "风险评估-Q3\n问题数量: 5\n关键风险: 2个\n风险等级: 高"
          }
        },
        {
          "id": "a1_4",
          "type": "exists",
          "label": "验证文件创建",
          "params": {
            "path": "{{params.data_dir}}"
          }
        }
      ]
    },
    {
      "id": "step_2",
      "type": "file",
      "label": "2.扫描文件列表",
      "actions": [
        {
          "id": "a2_1",
          "type": "list",
          "config": {
            "path": "{{params.data_dir}}",
            "pattern": "{{params.file_pattern}}"
          }
        }
      ]
    },
    {
      "id": "step_3",
      "type": "script",
      "label": "3.构建审批清单",
      "config": {
        "script": "let files = step_2.a2_1;\nlet total = files.len();\nlet items = [];\nfor f in files {\n    items.push(#{file: f.name, path: f.path, risk_level: if f.name.contains(\"涉密\") { \"高\" } else if f.name.contains(\"合规\") { \"中\" } else { \"低\" }});\n}\n#{total: total, items: items}"
      }
    },
    {
      "id": "step_4",
      "type": "logic",
      "label": "4.判断是否有待审批文件",
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_3.total}}",
              "op": "gt",
              "right": "0"
            }
          ]
        }
      }
    },
    {
      "id": "step_5",
      "type": "cursor",
      "label": "5.逐项审批处理",
      "config": {
        "items": "{{step_3.items}}"
      },
      "body_steps": [
        {
          "id": "body_5_1",
          "type": "file",
          "actions": [
            {
              "id": "ab5_1",
              "type": "read",
              "config": {
                "path": "{{__item.path}}"
              }
            }
          ]
        },
        {
          "id": "body_5_2",
          "type": "script",
          "config": {
            "script": "let content = body_5_1.ab5_1;\nlet has_secret = content.contains(\"涉密\");\nlet risk_score = if has_secret { 90 } else if content.contains(\"合规\") { 30 } else { 10 };\n#{risk_score: risk_score, has_secret: has_secret, content_length: content.len(), preview: content.sub_string(0, 30)}"
          }
        },
        {
          "id": "body_5_3",
          "type": "approval",
          "config": {
            "title": "文件审批: {{__item.file}}",
            "message": "风险等级: {{__item.risk_level}}\n风险评分: {{body_5_2.risk_score}}分\n内容预览: {{body_5_2.preview}}",
            "options": "同意发布,拒绝发布,需修改后重审",
            "require_review": false,
            "timeout": "{{params.approval_timeout_ms}}",
            "timeout_behavior": "auto",
            "timeout_action": "recommended",
            "approval_conditions": [
              {
                "id": "ac1",
                "left": "{{body_5_2.risk_score}}",
                "op": "lt",
                "right": "80"
              },
              {
                "id": "ac2",
                "left": "{{body_5_2.has_secret}}",
                "op": "equals",
                "right": "false"
              }
            ]
          }
        },
        {
          "id": "body_5_4",
          "type": "logic",
          "label": "判断审批结果",
          "config": {
            "conditionGroup": {
              "combinator": "and",
              "conditions": [
                {
                  "id": "lc1",
                  "left": "{{body_5_3.decision}}",
                  "op": "equals",
                  "right": "同意发布"
                }
              ]
            }
          }
        },
        {
          "id": "body_5_5",
          "type": "file",
          "label": "归档已批准文件",
          "runCondition": {
            "ref": "body_5_4",
            "when": "true"
          },
          "actions": [
            {
              "id": "ab5_5a",
              "type": "copy",
              "config": {
                "from": "{{__item.path}}",
                "to": "{{params.data_dir}}/approved/{{__item.file}}"
              }
            }
          ]
        },
        {
          "id": "body_5_6",
          "type": "file",
          "label": "归档已拒绝文件",
          "runCondition": {
            "ref": "body_5_4",
            "when": "false"
          },
          "actions": [
            {
              "id": "ab5_6a",
              "type": "copy",
              "config": {
                "from": "{{__item.path}}",
                "to": "{{params.data_dir}}/rejected/{{__item.file}}"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "step_6",
      "type": "file",
      "label": "6.汇总审批结果",
      "actions": [
        {
          "id": "a6_1",
          "type": "list",
          "config": {
            "path": "{{params.data_dir}}/approved"
          }
        },
        {
          "id": "a6_2",
          "type": "list",
          "config": {
            "path": "{{params.data_dir}}/rejected"
          }
        }
      ]
    },
    {
      "id": "step_7",
      "type": "script",
      "label": "7.统计汇总",
      "config": {
        "script": "let approved_list = step_6.a6_1;\nlet rejected_list = step_6.a6_2;\nlet approved = approved_list.len();\nlet rejected = rejected_list.len();\nlet total = approved + rejected;\nlet summary = \"审批完成: \" + approved + \"通过/\" + rejected + \"拒绝\";\n#{approved: approved, rejected: rejected, total: total, summary: summary}"
      }
    },
    {
      "id": "step_8",
      "type": "notify",
      "label": "8.发送审批汇总",
      "config": {
        "notify_type": "system",
        "title": "📋 批量审批完成",
        "body": "{{step_7.summary}}\n已批准目录: {{params.data_dir}}/approved/\n已拒绝目录: {{params.data_dir}}/rejected/"
      }
    }
  ]
}
