{
  "name": "http-approval-pipeline",
  "description": "【教学模板 ④】API数据审批决策链 — HTTP获取→JSON解析→脚本评估→条件审批（动态条件推荐）→分支处理→导出归档。演示 approval_conditions 动态推荐 + runCondition 双分支。",
  "params": {
    "api_url": "https://jsonplaceholder.typicode.com/posts/1",
    "approval_timeout_ms": 10,
    "notify_title": "API数据审批",
    "work_dir": "C:\\Users\\haozi\\AppData\\Local\\Temp\\wf-approval-pipeline"
  },
  "steps": [
    {
      "id": "step_1",
      "type": "http",
      "label": "1.获取待审批数据",
      "onError": "ignore",
      "config": {
        "method": "GET",
        "url": "{{params.api_url}}",
        "timeout": 10000
      }
    },
    {
      "id": "step_2",
      "type": "json_parse",
      "label": "2.解析API响应",
      "config": {
        "data": "{{step_1.body}}"
      }
    },
    {
      "id": "step_3",
      "type": "script",
      "label": "3.数据质量评估",
      "config": {
        "script": "let data = step_2;\nlet id = data.id;\nlet userId = data.userId;\nlet title = data.title;\nlet body = data.body;\nlet body_len = body.len;\nlet title_len = title.len;\nlet fields_ok = 4;\nlet quality = if body_len > 50 { 80.0 } else if body_len > 20 { 50.0 } else { 30.0 };\nlet level = if quality > 70 { \"优秀\" } else if quality > 40 { \"合格\" } else { \"差\" };\n#{id: id, userId: userId, title: title, body_len: body_len, title_len: title_len, fields_ok: fields_ok, quality: quality, level: level}"
      }
    },
    {
      "id": "step_4",
      "type": "logic",
      "label": "4.质量预筛选",
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_3.fields_ok}}",
              "op": "gte",
              "right": "4"
            },
            {
              "id": "c2",
              "left": "{{step_3.quality}}",
              "op": "gte",
              "right": "40"
            }
          ]
        }
      }
    },
    {
      "id": "step_5",
      "type": "approval",
      "label": "5.人工审批决策",
      "config": {
        "title": "数据发布审批",
        "message": "📊 数据质量: {{step_3.level}}（{{step_3.quality}}分）\n📝 标题: {{step_3.title}}\n🔑 ID: {{step_3.id}} | 用户: {{step_3.userId}}\n📏 字段完整: {{step_3.fields_ok}}/4 | 标题长度: {{step_3.title_len}} | 正文长度: {{step_3.body_len}}\n\n预筛选结果: {{step_4.branch}}",
        "options": "批准发布,拒绝发布,需修改",
        "recommended": "批准发布",
        "require_review": true,
        "timeout": "{{params.approval_timeout_ms}}",
        "timeout_behavior": "auto",
        "timeout_action": "recommended",
        "approval_conditions": [
          {
            "id": "ac1",
            "left": "{{step_3.quality}}",
            "op": "gte",
            "right": "60"
          },
          {
            "id": "ac2",
            "left": "{{step_3.fields_ok}}",
            "op": "gte",
            "right": "4"
          },
          {
            "id": "ac3",
            "left": "{{step_3.title_len}}",
            "op": "gt",
            "right": "5"
          }
        ]
      }
    },
    {
      "id": "step_6",
      "type": "logic",
      "label": "6.判断审批结果",
      "config": {
        "conditionGroup": {
          "combinator": "or",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_5.decision}}",
              "op": "equals",
              "right": "批准发布"
            },
            {
              "id": "c2",
              "left": "{{step_5.decision}}",
              "op": "equals",
              "right": "需修改"
            }
          ]
        }
      }
    },
    {
      "id": "step_7",
      "type": "file",
      "label": "7a.导出批准记录",
      "runCondition": {
        "ref": "step_6",
        "when": "true"
      },
      "actions": [
        {
          "id": "a7_1",
          "type": "write",
          "config": {
            "path": "{{params.work_dir}}/approval-decision.json",
            "content": "{\"id\":{{step_3.id}},\"title\":\"{{step_3.title}}\",\"decision\":\"{{step_5.decision}}\",\"quality\":{{step_3.quality}},\"comment\":\"{{step_5.comment}}\"}"
          }
        }
      ]
    },
    {
      "id": "step_8",
      "type": "file",
      "label": "7b.记录拒绝日志",
      "runCondition": {
        "ref": "step_6",
        "when": "false"
      },
      "config": {},
      "actions": [
        {
          "id": "a8_1",
          "type": "append",
          "label": "记录拒绝日志",
          "params": {
            "path": "{{params.work_dir}}/wf-rejected.log",
            "content": "[REJECTED] ID:{{step_3.id}} - {{step_3.title}} - 决策:{{step_5.decision}}"
          }
        }
      ]
    },
    {
      "id": "step_9",
      "type": "notify",
      "label": "8a.通知批准结果",
      "runCondition": {
        "ref": "step_6",
        "when": "true"
      },
      "config": {
        "notify_type": "system",
        "title": "✅ {{params.notify_title}} — 通过",
        "body": "ID={{step_3.id}} 标题={{step_3.title}}\n质量={{step_3.quality}}分({{step_3.level}})\n决策={{step_5.decision}}"
      }
    },
    {
      "id": "step_10",
      "type": "notify",
      "label": "8b.通知拒绝结果",
      "runCondition": {
        "ref": "step_6",
        "when": "false"
      },
      "config": {
        "notify_type": "system",
        "title": "❌ {{params.notify_title}} — 未通过",
        "body": "ID={{step_3.id}} 标题={{step_3.title}}\n决策={{step_5.decision}} 意见={{step_5.comment}}"
      }
    }
  ]
}
