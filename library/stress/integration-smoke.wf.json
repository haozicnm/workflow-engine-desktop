{
  "name": "integration-smoke",
  "description": "【教学模板 ①】全类型演练 — 覆盖全部14种节点，数据在每个容器间传递。适合学习变量引用、容器链式调用、条件分支。",
  "params": {
    "test_dir": "/tmp/wf-smoke-test",
    "items_list": "[\"alpha\",\"beta\",\"gamma\"]",
    "delay_ms": 300
  },
  "steps": [
    {
      "id": "step_1",
      "type": "script",
      "label": "1.生成测试数据",
      "config": {
        "script": "\"{\\\"project\\\":\\\"WF教学演练\\\",\\\"items\\\":[{\\\"id\\\":1,\\\"name\\\":\\\"需求分析\\\",\\\"score\\\":85,\\\"pass\\\":true},{\\\"id\\\":2,\\\"name\\\":\\\"架构设计\\\",\\\"score\\\":92,\\\"pass\\\":true},{\\\"id\\\":3,\\\"name\\\":\\\"代码审查\\\",\\\"score\\\":78,\\\"pass\\\":true},{\\\"id\\\":4,\\\"name\\\":\\\"集成测试\\\",\\\"score\\\":55,\\\"pass\\\":false}]}\""
      }
    },
    {
      "id": "step_2",
      "type": "json_parse",
      "label": "2.解析JSON数据",
      "config": {
        "data": "{{step_1}}"
      }
    },
    {
      "id": "step_3",
      "type": "file",
      "label": "3.存档原始数据",
      "actions": [
        {
          "id": "a3_1",
          "type": "write",
          "config": {
            "path": "{{params.test_dir}}/t1-raw.json",
            "content": "{{step_1}}"
          }
        }
      ]
    },
    {
      "id": "step_4",
      "type": "file",
      "label": "4.回读验证存档",
      "actions": [
        {
          "id": "a4_1",
          "type": "read",
          "config": {
            "path": "{{params.test_dir}}/t1-raw.json"
          }
        }
      ]
    },
    {
      "id": "step_5",
      "type": "script",
      "label": "5.数据统计计算",
      "config": {
        "script": "let items = step_2.items;\nlet count = items.len;\nlet max = 0.0;\nlet min = 100.0;\nlet sum = 0.0;\nlet pass_count = 0;\nfor item in items {\n    if item.score > max { max = item.score; }\n    if item.score < min { min = item.score; }\n    sum += item.score;\n    if item.pass { pass_count += 1; }\n}\nlet avg = sum / count;\nlet pass_rate = pass_count * 100 / count;\n#{avg: avg, max: max, min: min, count: count, pass_count: pass_count, pass_rate: pass_rate}"
      }
    },
    {
      "id": "step_6",
      "type": "logic",
      "label": "6.判断通过率",
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_5.avg}}",
              "op": "gte",
              "right": "60"
            },
            {
              "id": "c2",
              "left": "{{step_5.pass_rate}}",
              "op": "gte",
              "right": "50"
            }
          ]
        }
      }
    },
    {
      "id": "step_7",
      "type": "http",
      "label": "7.获取外部基准数据",
      "onError": "ignore",
      "config": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/1",
        "timeout": 10000
      }
    },
    {
      "id": "step_8",
      "type": "excel",
      "label": "8.生成Excel报表",
      "config": {
        "file_path": "{{params.test_dir}}/t1-report.xlsx",
        "actions": [
          {
            "id": "a8_1",
            "type": "create",
            "config": {
              "headers": "阶段,分数,是否通过"
            }
          },
          {
            "id": "a8_2",
            "type": "write",
            "config": {
              "value": [
                [
                  "需求分析",
                  85,
                  "是"
                ],
                [
                  "架构设计",
                  92,
                  "是"
                ],
                [
                  "代码审查",
                  78,
                  "是"
                ],
                [
                  "集成测试",
                  55,
                  "否"
                ]
              ]
            }
          },
          {
            "id": "a8_3",
            "type": "sort",
            "config": {
              "column": "分数",
              "order": "desc"
            }
          }
        ]
      }
    },
    {
      "id": "step_9",
      "type": "word",
      "label": "9.生成Word总结文档",
      "config": {
        "file_path": "{{params.test_dir}}/t1-summary.docx",
        "actions": [
          {
            "id": "a9_1",
            "type": "create",
            "config": {
              "title": "工作流教学演练 — 数据报告"
            }
          },
          {
            "id": "a9_2",
            "type": "write",
            "config": {
              "value": "项目：WF教学演练\n平均分：{{step_5.avg}}分 | 最高：{{step_5.max}}分 | 最低：{{step_5.min}}分\n通过率：{{step_5.pass_rate}}%（{{step_5.pass_count}}/{{step_5.count}}）\n状态：{{step_6.branch}}（条件判断结果）\n外部API响应：HTTP {{step_7.status}}"
            }
          }
        ]
      }
    },
    {
      "id": "step_10",
      "type": "clipboard",
      "label": "10.复制摘要到剪贴板",
      "config": {
        "action": "write",
        "text": "[WF教学演练] 平均分{{step_5.avg}} 通过率{{step_5.pass_rate}}% 状态:{{step_6.branch}}"
      }
    },
    {
      "id": "step_11",
      "type": "loop",
      "label": "11.逐项处理通知",
      "config": {
        "items": "{{step_2.items}}"
      },
      "body_steps": [
        {
          "id": "body_11_1",
          "type": "script",
          "config": {
            "script": "let item = __item;\n#{name: item.name, score: item.score, status: if item.pass { \"✅通过\" } else { \"❌未通过\" }}"
          }
        },
        {
          "id": "body_11_2",
          "type": "delay",
          "config": {
            "duration_ms": "{{params.delay_ms}}"
          }
        }
      ]
    },
    {
      "id": "step_12",
      "type": "notify",
      "label": "12.发送完成通知",
      "config": {
        "notify_type": "system",
        "title": "教学演练完成",
        "body": "全部{{step_5.count}}项已处理\n通过率: {{step_5.pass_rate}}%\n报表: {{params.test_dir}}/t1-report.xlsx\n文档: {{params.test_dir}}/t1-summary.docx"
      }
    },
    {
      "id": "step_13",
      "type": "delay",
      "label": "13.等待收尾",
      "config": {
        "duration_ms": "{{params.delay_ms}}"
      }
    },
    {
      "id": "step_14",
      "type": "file",
      "label": "14.清理临时文件",
      "actions": [
        {
          "id": "a14_1",
          "type": "delete",
          "label": "清理存档文件",
          "params": {
            "path": "{{params.test_dir}}/t1-raw.json"
          }
        },
        {
          "id": "a14_2",
          "type": "delete",
          "label": "清理报表文件",
          "params": {
            "path": "{{params.test_dir}}/t1-report.xlsx"
          }
        },
        {
          "id": "a14_3",
          "type": "delete",
          "label": "清理文档文件",
          "params": {
            "path": "{{params.test_dir}}/t1-summary.docx"
          }
        }
      ]
    }
  ]
}
