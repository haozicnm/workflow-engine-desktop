{"name":"文档摘要生成","description":"读取文档内容，用 LLM 生成摘要","steps":[{"id":"read","type":"file_read","config":{"path":"{{params.file_path}}"}},{"id":"prompt","type":"prompt_template","config":{"template":"请为以下文档生成200字以内的摘要:\n\n{{read.content}}","system_prompt":"你是一个专业的文档分析师"}},{"id":"summarize","type":"llm_chat","config":{"api_key":"{{params.api_key}}","model":"gpt-4o","messages":"{{prompt.messages}}","temperature":0.3}},{"id":"save","type":"file_write","config":{"path":"{{params.output_path}}","content":"{{summarize.content}}"}}],"variables":{"file_path":"","output_path":"summary.txt","api_key":""}}
