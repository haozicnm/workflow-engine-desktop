{"name":"系统健康检查","description":"检查系统资源使用情况并报告","steps":[{"id":"cpu","type":"shell","config":{"command":"top -bn1 | grep 'Cpu(s)' | awk '{print $2}'"}},{"id":"mem","type":"shell","config":{"command":"free -m | awk 'NR==2{printf \"%s/%sMB\", $3, $2}'"}},{"id":"disk","type":"shell","config":{"command":"df -h / | awk 'NR==2{print $5}'"}},{"id":"report","type":"data_set","config":{"key":"health","value":"CPU: {{cpu}}, 内存: {{mem}}, 磁盘: {{disk}}"}}],"variables":{}}
