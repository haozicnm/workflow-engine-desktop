{
  "description": "多层runCondition嵌套分叉+retry重试+onError分支跳转+loop内嵌browser/http/logic+跨Step变量引用。压力测试容错和变量传递链路",
  "name": "嵌套容错链压力测试",
  "params": {
    "items": "TODO: replace with {{params.items}}",
    "test_dir": "TODO: replace with {{params.test_dir}}"
  },
  "steps": [
    {
      "config": {
        "command": "mkdir -p /tmp/wf-stress-test/{input,output,logs} && echo \"dirs_created\"",
        "shell": "bash",
        "timeout_secs": 10
      },
      "headless": true,
      "id": "step_1",
      "label": "创建测试目录结构",
      "type": "shell"
    },
    {
      "actions": [
        {
          "id": "action_2_1",
          "label": "写入input1",
          "params": {
            "content": "hello world from step_2",
            "path": "/tmp/wf-stress-test/input/data1.txt"
          },
          "type": "write"
        },
        {
          "id": "action_2_2",
          "label": "写入input2",
          "params": {
            "content": "second file content",
            "path": "/tmp/wf-stress-test/input/data2.txt"
          },
          "type": "write"
        },
        {
          "id": "action_2_3",
          "label": "验证文件存在",
          "params": {
            "path": "/tmp/wf-stress-test/input/data1.txt"
          },
          "type": "exists"
        }
      ],
      "config": {},
      "headless": true,
      "id": "step_2",
      "label": "准备测试数据",
      "type": "file"
    },
    {
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_2.action_2_3.result}}",
              "op": "equals",
              "right": "true"
            }
          ]
        }
      },
      "headless": true,
      "id": "step_3",
      "label": "文件是否就绪",
      "type": "logic"
    },
    {
      "actions": [
        {
          "id": "action_4_1",
          "label": "打开httpbin",
          "params": {
            "url": "https://httpbin.org/get?source=wf-stress",
            "wait_until": "networkidle"
          },
          "type": "navigate"
        },
        {
          "id": "action_4_2",
          "label": "提取正文",
          "params": {
            "mode": "text",
            "selector": "body pre"
          },
          "type": "extract"
        }
      ],
      "config": {
        "browser": "chromium",
        "headless": true,
        "timeout": 30
      },
      "headless": true,
      "id": "step_4",
      "label": "访问测试页面",
      "retry": {
        "delay_ms": 2000,
        "max": 2
      },
      "runCondition": {
        "ref": "step_3",
        "when": "true"
      },
      "type": "browser"
    },
    {
      "actions": [
        {
          "id": "action_5_1",
          "label": "打开备用",
          "params": {
            "url": "https://example.com",
            "wait_until": "domcontentloaded"
          },
          "type": "navigate"
        },
        {
          "id": "action_5_2",
          "label": "获取标题",
          "params": {},
          "type": "get_title"
        }
      ],
      "config": {
        "browser": "chromium",
        "headless": true,
        "timeout": 20
      },
      "headless": true,
      "id": "step_5",
      "label": "访问备用页面(容错分支)",
      "runCondition": {
        "ref": "step_3",
        "when": "false"
      },
      "type": "browser"
    },
    {
      "config": {
        "body": "{\"result\": \"{{step_4.action_4_2.result.text}}\", \"stage\": \"after_browser\"}",
        "headers": "{\"Content-Type\": \"application/json\"}",
        "method": "POST",
        "url": "https://httpbin.org/post"
      },
      "headless": true,
      "id": "step_6",
      "label": "POST处理结果(容错)",
      "retry": {
        "delay_ms": 1000,
        "max": 1
      },
      "runCondition": {
        "ref": "step_3",
        "when": "true"
      },
      "type": "http"
    },
    {
      "actions": [
        {
          "id": "action_7_1",
          "label": "POST item",
          "params": {
            "body": "{\"item\": \"{{loop.current}}\", \"batch\": \"stress-test\"}",
            "headers": "{\"Content-Type\": \"application/json\"}",
            "method": "POST",
            "url": "https://httpbin.org/post"
          },
          "type": "http"
        },
        {
          "id": "action_7_2",
          "label": "短暂等待",
          "params": {
            "duration_ms": 300
          },
          "type": "delay"
        },
        {
          "id": "action_7_3",
          "label": "记录进度",
          "params": {
            "script": "#{item: __item, index: __index}"
          },
          "type": "script"
        },
        {
          "id": "action_7_4",
          "label": "进度通知",
          "params": {
            "body": "{{action_7_3.result.processed}} ({{loop.index}}/3)",
            "notify_type": "system",
            "title": "Loop进度"
          },
          "type": "notify"
        }
      ],
      "config": {
        "items": "[\"alpha\", \"beta\", \"gamma\"]"
      },
      "headless": true,
      "id": "step_7",
      "label": "批量POST测试",
      "onError": "ignore",
      "type": "loop"
    },
    {
      "config": {
        "conditionGroup": {
          "combinator": "or",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_7.result.status}}",
              "op": "equals",
              "right": "completed"
            },
            {
              "id": "c2",
              "left": "{{step_7.result.status}}",
              "op": "equals",
              "right": "completed_with_errors"
            }
          ]
        }
      },
      "headless": true,
      "id": "step_8",
      "label": "循环是否成功",
      "type": "logic"
    },
    {
      "config": {
        "command": "echo \"[PASS] All stress tests completed successfully\" && ls -la /tmp/wf-stress-test/output/ 2>/dev/null || echo \"no output files\"",
        "shell": "bash",
        "timeout_secs": 10
      },
      "headless": true,
      "id": "step_9",
      "label": "成功总结",
      "runCondition": {
        "ref": "step_8",
        "when": "true"
      },
      "type": "shell"
    },
    {
      "config": {
        "command": "echo \"[FAIL] Some tests failed at loop stage\" && cat /tmp/wf-stress-test/logs/*.log 2>/dev/null || echo \"no logs\"",
        "shell": "bash",
        "timeout_secs": 10
      },
      "headless": true,
      "id": "step_10",
      "label": "失败处理",
      "runCondition": {
        "ref": "step_8",
        "when": "false"
      },
      "type": "shell"
    },
    {
      "config": {
        "duration_ms": 500
      },
      "headless": true,
      "id": "step_11",
      "label": "最终等待",
      "type": "delay"
    },
    {
      "config": {
        "body": "状态: {{step_8.result.result}}",
        "notify_type": "system",
        "title": "压力测试完成"
      },
      "headless": true,
      "id": "step_12",
      "label": "完成通知",
      "onError": "ignore",
      "type": "notify"
    }
  ]
}