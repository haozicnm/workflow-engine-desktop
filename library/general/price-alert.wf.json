{"name":"价格监控与通知","description":"监控商品价格变化并通知","steps":[{"id":"fetch","type":"http","config":{"url":"{{params.product_url}}"}},{"id":"extract","type":"script","config":{"language":"javascript","script":"const m = body.match(/price['\"]?\\s*[:=]\\s*['\"]?([\\d.]+)/); return m ? parseFloat(m[1]) : 0"}},{"id":"check","type":"condition","config":{"condition":"{{extract}} < {{params.target_price}}"}},{"id":"alert","type":"im_message","config":{"platform":"telegram","webhook_url":"{{params.webhook}}","title":"价格提醒","text":"商品价格已降至 {{extract}}，低于目标价 {{params.target_price}}"}}],"variables":{"product_url":"","target_price":0,"webhook":""}}
