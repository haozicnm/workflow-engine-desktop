{"name":"网页数据采集","description":"抓取网页内容并提取结构化数据","steps":[{"id":"fetch","type":"http","config":{"url":"{{params.url}}"}},{"id":"extract","type":"script","config":{"language":"javascript","script":"const titles = body.match(/<h[1-3][^>]*>(.*?)<\\/h[1-3]>/gi) || []; return titles.map(t => t.replace(/<[^>]+>/g, '').trim()).slice(0, 20)"}},{"id":"save","type":"file_write","config":{"path":"{{params.output}}","content":"{{extract}}"}},{"id":"notify","type":"im_message","config":{"platform":"feishu","webhook_url":"{{params.webhook}}","title":"数据采集","text":"从 {{params.url}} 提取了 {{extract.length}} 条数据"}}],"variables":{"url":"","output":"scraped.json","webhook":""}}
