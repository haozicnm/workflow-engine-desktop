{"name":"文件批量重命名","description":"批量重命名指定目录下的文件","steps":[{"id":"list","type":"file_list","config":{"path":"{{params.dir}}","recursive":false}},{"id":"rename","type":"loop","config":{"items":"{{list.entries}}","body":[{"id":"mv","type":"shell","config":{"command":"mv \"{{__item.path}}\" \"{{params.dir}}/{{params.prefix}}_{{__index1}}.{{__item.name.split('.').pop()}}\""}}]}}],"variables":{"dir":"","prefix":"file"}}
