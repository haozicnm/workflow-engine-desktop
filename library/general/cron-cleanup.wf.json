{"name":"定时清理临时文件","description":"定期清理指定目录下的临时文件","steps":[{"id":"trigger","type":"trigger_cron","config":{"cron_expr":"0 0 2 * * *"}},{"id":"find","type":"shell","config":{"command":"find {{params.temp_dir}} -type f -mtime +{{params.days}} -name '*.tmp'"}},{"id":"delete","type":"shell","config":{"command":"find {{params.temp_dir}} -type f -mtime +{{params.days}} -name '*.tmp' -delete"}},{"id":"notify","type":"im_message","config":{"platform":"wecom","webhook_url":"{{params.webhook}}","title":"临时文件清理","text":"已清理 {{params.temp_dir}} 中超过 {{params.days}} 天的临时文件"}}],"variables":{"temp_dir":"/tmp","days":7,"webhook":""}}
