{"name":"数据同步","description":"定时同步两个数据库之间的数据","steps":[{"id":"source","type":"database_query","config":{"db_type":"sqlite","connection":"{{params.source_db}}","sql":"SELECT * FROM {{params.table}} WHERE updated_at > datetime('now', '-1 hour')"}},{"id":"sync","type":"loop","config":{"items":"{{source.rows}}","body":[{"id":"upsert","type":"database_query","config":{"db_type":"sqlite","connection":"{{params.target_db}}","sql":"INSERT OR REPLACE INTO {{params.table}} (id, data, updated_at) VALUES (?, ?, ?)","params":"[__item.id, __item.data, __item.updated_at]","allow_write":true}}]}},{"id":"report","type":"data_set","config":{"key":"synced","value":"{{sync.count}}"}}],"variables":{"source_db":"","target_db":"","table":"data"}}
