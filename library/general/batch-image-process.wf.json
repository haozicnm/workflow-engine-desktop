{"name":"批量图片处理","description":"批量压缩/转换图片文件","steps":[{"id":"list","type":"file_list","config":{"path":"{{params.input_dir}}","recursive":false}},{"id":"process","type":"loop","config":{"items":"{{list.entries}}","body":[{"id":"convert","type":"shell","config":{"command":"convert {{__item.path}} -resize {{params.max_width}}x{{params.max_height}} {{params.output_dir}}/{{__item.name}}"}}]}},{"id":"report","type":"data_set","config":{"key":"processed","value":"{{process.count}}"}}],"variables":{"input_dir":"","output_dir":"","max_width":800,"max_height":600}}
