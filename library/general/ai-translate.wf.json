{"name":"多语言翻译","description":"用 LLM 将文本翻译为目标语言","steps":[{"id":"read","type":"file_read","config":{"path":"{{params.input_file}}"}},{"id":"translate","type":"llm_chat","config":{"api_key":"{{params.api_key}}","model":"gpt-4o-mini","messages":[{"role":"system","content":"翻译为{{params.target_lang}}，保持原文格式。"},{"role":"user","content":"{{read.content}}"}],"temperature":0.3}},{"id":"save","type":"file_write","config":{"path":"{{params.output_file}}","content":"{{translate.content}}"}}],"variables":{"input_file":"","output_file":"translated.txt","target_lang":"English","api_key":""}}
