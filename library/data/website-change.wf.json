{"name":"网站变更检测","description":"定时检测网页内容变化，变化时通知","steps":[{"id":"fetch","type":"http","config":{"url":"{{params.url}}"}},{"id":"hash","type":"script","config":{"language":"javascript","script":"let h = 0; for(let i=0;i<body.length;i++) h = ((h<<5)-h)+body.charCodeAt(i); return h"}},{"id":"check","type":"condition","config":{"condition":"{{hash}} != {{params.last_hash}}"}},{"id":"alert","type":"im_message","config":{"platform":"slack","webhook_url":"{{params.webhook}}","title":"网站变更","text":"{{params.url}} 内容已变更"}}],"variables":{"url":"","last_hash":"0","webhook":""}}
