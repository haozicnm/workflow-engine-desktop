{"name":"竞品价格监控","description":"定时抓取竞品页面价格，变化时告警","steps":[{"id":"fetch","type":"http","config":{"url":"{{params.url}}","method":"GET"}},{"id":"extract","type":"script","config":{"language":"javascript","script":"const m = body.match(/¥([\\d.]+)/); return m ? m[1] : 'N/A'"}},{"id":"check","type":"condition","config":{"condition":"{{extract}} != {{params.last_price}}"}},{"id":"alert","type":"im_message","config":{"platform":"dingtalk","webhook_url":"{{params.webhook}}","title":"价格变动","text":"竞品价格从 {{params.last_price}} 变为 {{extract}}"}}],"variables":{"url":"","last_price":"0","webhook":""}}
