{"name":"CSV 数据清洗","description":"读取 CSV 文件，过滤空行，去重，输出清洗后的数据","steps":[{"id":"read","type":"file_read","config":{"path":"{{params.input_file}}"}},{"id":"parse","type":"script","config":{"language":"javascript","script":"return content.split('\\n').filter(l => l.trim())"}},{"id":"filter","type":"data_filter","config":{"expression":"__item != ''"}},{"id":"write","type":"file_write","config":{"path":"{{params.output_file}}","content":"{{filter.filtered}}","mode":"overwrite"}}],"variables":{"input_file":"","output_file":""}}
