{
  "name": "integration-smoke",
  "description": "【教学模板 ①】全类型演练 — 覆盖全部14种节点，数据在每个容器间传递。适合学习变量引用、容器链式调用、条件分支。",
  "params": {
    "test_dir": "/tmp/wf-smoke-test",
    "items_list": "[\"alpha\",\"beta\",\"gamma\"]",
    "delay_ms": 300
  },
  "steps": [
    {
      "id": "step_1",
      "type": "shell",
      "name": "1.生成测试数据",
      "config": {
        "command": "echo '{\"project\":\"WF教学演练\",\"items\":[{\"id\":1,\"name\":\"需求分析\",\"score\":85,\"pass\":true},{\"id\":2,\"name\":\"架构设计\",\"score\":92,\"pass\":true},{\"id\":3,\"name\":\"代码审查\",\"score\":78,\"pass\":true},{\"id\":4,\"name\":\"集成测试\",\"score\":55,\"pass\":false}]}'",
        "shell": "powershell",
        "timeout_secs": 5
      }
    },
    {
      "id": "step_2",
      "type": "json_parse",
      "name": "2.解析JSON数据",
      "config": {
        "data": "{{step_1.stdout}}"
      }
    },
    {
      "id": "step_3",
      "type": "file",
      "name": "3.存档原始数据",
      "actions": [
        {
          "id": "a3_1",
          "type": "write",
          "config": {
            "path": "/tmp/wf-t1-raw.json",
            "content": "{{step_1.stdout}}"
          }
        }
      ]
    },
    {
      "id": "step_4",
      "type": "file",
      "name": "4.回读验证存档",
      "actions": [
        {
          "id": "a4_1",
          "type": "read",
          "config": {
            "path": "/tmp/wf-t1-raw.json"
          }
        }
      ]
    },
    {
      "id": "step_5",
      "type": "script",
      "name": "5.数据统计计算",
      "config": {
        "script": "// Rhai脚本：遍历数据做统计分析\nlet raw = step_4.to_string();\nlet data = parse_json(raw);\n\n// 计算分数统计\nlet total = 0.0;\nlet count = 0;\nlet max = 0.0;\nlet min = 999.0;\nlet pass_count = 0;\n\nfor item in data.items {\n    let score = item.score;\n    total += score;\n    count += 1;\n    if score > max { max = score; }\n    if score < min { min = score; }\n    if item.pass { pass_count += 1; }\n}\n\nlet avg = total / count;\nlet pass_rate = pass_count * 100 / count;\n\n#{ avg: avg, max: max, min: min, count: count, pass_count: pass_count, pass_rate: pass_rate }"
      }
    },
    {
      "id": "step_6",
      "type": "logic",
      "name": "6.判断通过率",
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            { "id": "c1", "left": "{{step_5.avg}}", "op": "gt", "right": "60" },
            { "id": "c2", "left": "{{step_5.pass_rate}}", "op": "gte", "right": "50" }
          ]
        }
      }
    },
    {
      "id": "step_7",
      "type": "http",
      "name": "7.获取外部基准数据",
      "config": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/1",
        "timeout": 10000
      }
    },
    {
      "id": "step_8",
      "type": "excel",
      "name": "8.生成Excel报表",
      "config": {
        "file_path": "/tmp/wf-t1-report.xlsx",
        "sheet": "评分汇总"
      },
      "actions": [
        {
          "id": "a8_1",
          "type": "create",
          "config": { "headers": "阶段,分数,是否通过" }
        },
        {
          "id": "a8_2",
          "type": "write",
          "config": {
            "value": [
              ["需求分析", 85, "是"],
              ["架构设计", 92, "是"],
              ["代码审查", 78, "是"],
              ["集成测试", 55, "否"]
            ]
          }
        },
        {
          "id": "a8_3",
          "type": "sort",
          "config": { "column": "分数", "order": "desc" }
        }
      ]
    },
    {
      "id": "step_9",
      "type": "word",
      "name": "9.生成Word总结文档",
      "config": { "file_path": "/tmp/wf-t1-summary.docx" },
      "actions": [
        {
          "id": "a9_1",
          "type": "create",
          "config": { "title": "工作流教学演练 — 数据报告" }
        },
        {
          "id": "a9_2",
          "type": "write",
          "config": {
            "value": "项目：WF教学演练\n平均分：{{step_5.avg}}分 | 最高：{{step_5.max}}分 | 最低：{{step_5.min}}分\n通过率：{{step_5.pass_rate}}%（{{step_5.pass_count}}/{{step_5.count}}）\n状态：{{step_6.branch}}（条件判断结果）\n外部API响应：HTTP {{step_7.status}}"
          }
        }
      ]
    },
    {
      "id": "step_10",
      "type": "clipboard",
      "name": "10.复制摘要到剪贴板",
      "config": {
        "action": "write",
        "text": "[WF教学演练] 平均分{{step_5.avg}} 通过率{{step_5.pass_rate}}% 状态:{{step_6.branch}}"
      }
    },
    {
      "id": "step_11",
      "type": "loop",
      "name": "11.逐项处理通知",
      "config": {
        "items": "{{step_2.result.items}}"
      },
      "body_steps": [
        {
          "id": "body_11_1",
          "type": "script",
          "config": {
            "script": "let status = if __item.pass { \"✅通过\" } else { \"❌未通过\" };\n#{ item_name: __item.name, score: __item.score, status: status }"
          }
        },
        {
          "id": "body_11_2",
          "type": "delay",
          "config": { "duration_ms": 150 }
        }
      ]
    },
    {
      "id": "step_12",
      "type": "notify",
      "name": "12.发送完成通知",
      "config": {
        "notify_type": "system",
        "title": "教学演练完成",
        "body": "全部{{step_5.count}}项已处理\n通过率: {{step_5.pass_rate}}%\n报表: /tmp/wf-t1-report.xlsx\n文档: /tmp/wf-t1-summary.docx"
      }
    },
    {
      "id": "step_13",
      "type": "delay",
      "name": "13.等待收尾",
      "config": { "duration_ms": 200 }
    },
    {
      "id": "step_14",
      "type": "shell",
      "name": "14.清理临时文件",
      "config": {
        "command": "Remove-Item /tmp/wf-t1-raw.json,/tmp/wf-t1-report.xlsx,/tmp/wf-t1-summary.docx -ErrorAction SilentlyContinue; Write-Output 'cleaned'",
        "shell": "powershell",
        "timeout_secs": 5
      }
    }
  ]
}
