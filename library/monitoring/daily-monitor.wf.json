{
  "name": "daily-monitor",
  "description": "【教学模板 ②】每日智能舆情报告 — 多API聚合→解析→计算→条件→报表→通知。演示 HTTP 管道、数据转换链、Excel/Word 报表生成。",
  "params": {
    "hn_api": "https://hacker-news.firebaseio.com/v0/topstories.json",
    "github_api": "https://api.github.com/repos/haozicnm/workflow-engine-desktop",
    "output_dir": "/tmp/wf-daily-report"
  },
  "steps": [
    {
      "id": "step_1",
      "type": "http",
      "label": "2.获取HN热榜",
      "onError": "ignore",
      "config": {
        "method": "GET",
        "url": "{{params.hn_api}}",
        "timeout": 15000
      }
    },
    {
      "id": "step_2",
      "type": "json_parse",
      "label": "3.解析ID列表",
      "config": {
        "data": "{{step_1.body}}"
      }
    },
    {
      "id": "step_3",
      "type": "script",
      "label": "4.摘要统计",
      "config": {
        "script": "let ids = step_2;\nlet total = ids.len();\nlet top_n = if total > 10 { 10 } else { total };\nlet top_ids = [];\nfor i in 0..top_n {\n    top_ids.push(ids[i].to_string());\n}\n#{top_ids: top_ids.join(\",\"), total: total, top_count: top_n, source: \"HackerNews\"}"
      }
    },
    {
      "id": "step_4",
      "type": "http",
      "label": "5.获取GitHub仓库状态",
      "onError": "ignore",
      "config": {
        "method": "GET",
        "url": "{{params.github_api}}",
        "headers": "{\"Accept\": \"application/vnd.github.v3+json\", \"User-Agent\": \"wf-engine/1.0\"}",
        "timeout": 15000
      }
    },
    {
      "id": "step_5",
      "type": "json_parse",
      "label": "6.解析GitHub数据",
      "config": {
        "data": "{{step_4.body}}"
      }
    },
    {
      "id": "step_6",
      "type": "script",
      "label": "7.综合计算评分",
      "config": {
        "script": "let repo = step_5;\nlet stars = repo.stargazers_count;\nlet forks = repo.forks_count;\nlet issues = repo.open_issues_count;\nlet name = repo.full_name;\nlet score = stars + forks * 2;\nlet level = if score > 100 { \"🔥热门\" } else if score > 50 { \"⭐活跃\" } else { \"💤休眠\" };\n#{stars: stars, forks: forks, open_issues: issues, score: score, level: level, repo: name}"
      }
    },
    {
      "id": "step_7",
      "type": "logic",
      "label": "8.活跃度判断",
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_6.score}}",
              "op": "gte",
              "right": "50"
            },
            {
              "id": "c2",
              "left": "{{step_6.stars}}",
              "op": "gt",
              "right": "0"
            }
          ]
        }
      }
    },
    {
      "id": "step_8",
      "type": "excel",
      "label": "9.生成Excel日报表",
      "config": {
        "file_path": "{{params.output_dir}}/daily-report.xlsx",
        "actions": [
          {
            "id": "a9_1",
            "type": "create",
            "config": {
              "headers": "数据源,指标,数值,状态"
            }
          },
          {
            "id": "a9_2",
            "type": "write",
            "config": {
              "value": [
                [
                  "HackerNews",
                  "热榜总数",
                  "{{step_3.total}}",
                  "正常"
                ],
                [
                  "HackerNews",
                  "Top10 ID",
                  "{{step_3.top_ids}}",
                  "-"
                ],
                [
                  "GitHub",
                  "Stars",
                  "{{step_6.stars}}",
                  "{{step_6.level}}"
                ],
                [
                  "GitHub",
                  "Forks",
                  "{{step_6.forks}}",
                  "-"
                ],
                [
                  "GitHub",
                  "Open Issues",
                  "{{step_6.open_issues}}",
                  "-"
                ],
                [
                  "综合",
                  "活跃度评分",
                  "{{step_6.score}}",
                  "{{step_7.branch}}"
                ]
              ]
            }
          },
          {
            "id": "a9_3",
            "type": "sort",
            "config": {
              "column": "数值",
              "order": "desc"
            }
          }
        ]
      }
    },
    {
      "id": "step_9",
      "type": "file",
      "label": "10.归档JSON快照",
      "actions": [
        {
          "id": "a9_1",
          "type": "write",
          "config": {
            "path": "{{params.output_dir}}/snapshot.json",
            "content": "{\"hn_count\":{{step_2.total}},\"gh_stars\":{{step_5.stars}},\"gh_forks\":{{step_5.forks}},\"score\":{{step_5.score}},\"level\":\"{{step_6.level}}\",\"condition\":\"{{step_6.branch}}\"}"
          }
        }
      ]
    },
    {
      "id": "step_10",
      "type": "word",
      "label": "11.生成Word日报摘要",
      "config": {
        "file_path": "{{params.output_dir}}/daily-summary.docx",
        "actions": [
          {
            "id": "a11_1",
            "type": "create",
            "config": {
              "title": "每日智能舆情报告"
            }
          },
          {
            "id": "a11_2",
            "type": "write",
            "config": {
              "value": "📊 数据源汇总\n• HackerNews热榜: {{step_2.total}}条\n• GitHub仓库({{step_5.repo}}): ⭐{{step_5.stars}} 🔱{{step_5.forks}} ⚠️{{step_5.open_issues}}\n\n📈 活跃度评分: {{step_5.score}}分 → {{step_5.level}}\n📋 综合判断: {{step_6.branch}}\n\n报表文件: {{params.output_dir}}/daily-report.xlsx\n快照文件: {{params.output_dir}}/snapshot.json"
            }
          }
        ]
      }
    },
    {
      "id": "step_11",
      "type": "notify",
      "label": "12.发送日报通知",
      "config": {
        "notify_type": "system",
        "title": "📊 每日舆情报告已生成",
        "body": "HN热榜{{step_2.total}}条 | GitHub活跃度:{{step_5.score}}分({{step_5.level}})\n报表: {{params.output_dir}}/daily-report.xlsx\n文档: {{params.output_dir}}/daily-summary.docx"
      }
    }
  ]
}