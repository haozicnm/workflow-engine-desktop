{
  "name": "daily-monitor",
  "description": "【教学模板 ②】每日智能舆情报告 — 多API聚合→解析→计算→条件→报表→通知。演示 HTTP 管道、数据转换链、Excel/Word 报表生成。",
  "params": {
    "hn_api": "https://hacker-news.firebaseio.com/v0/topstories.json",
    "github_api": "https://api.github.com/repos/haozicnm/workflow-engine-desktop",
    "output_dir": "/tmp/wf-daily-report"
  },
  "steps": [
    {
      "id": "step_1",
      "type": "shell",
      "name": "1.创建输出目录",
      "config": {
        "command": "mkdir -p /tmp/wf-daily-report; echo '/tmp/wf-daily-report'",
        "shell": "bash",
        "timeout_secs": 5
      }
    },
    {
      "id": "step_2",
      "type": "http",
      "name": "2.获取HN热榜",
      "config": {
        "method": "GET",
        "url": "https://hacker-news.firebaseio.com/v0/topstories.json",
        "timeout": 15000
      }
    },
    {
      "id": "step_3",
      "type": "json_parse",
      "name": "3.解析ID列表",
      "config": {
        "data": "{{step_2.body}}"
      }
    },
    {
      "id": "step_4",
      "type": "script",
      "name": "4.摘要统计",
      "config": {
        "script": "#{top_ids: \"1,2,3\", total: 10, top_count: 10, source: \"HackerNews\"}"
      }
    },
    {
      "id": "step_5",
      "type": "http",
      "name": "5.获取GitHub仓库状态",
      "config": {
        "method": "GET",
        "url": "https://api.github.com/repos/haozicnm/workflow-engine-desktop",
        "headers": "{\"Accept\": \"application/vnd.github.v3+json\", \"User-Agent\": \"wf-engine/1.0\"}",
        "timeout": 15000
      }
    },
    {
      "id": "step_6",
      "type": "json_parse",
      "name": "6.解析GitHub数据",
      "config": {
        "data": "{{step_5.body}}"
      }
    },
    {
      "id": "step_7",
      "type": "script",
      "name": "7.综合计算评分",
      "config": {
        "script": "#{stars: 0, forks: 0, open_issues: 0, score: 50.0, level: \"⭐中等\", repo: \"unknown\"}"
      }
    },
    {
      "id": "step_8",
      "type": "logic",
      "name": "8.活跃度判断",
      "config": {
        "conditionGroup": {
          "combinator": "and",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_7.score}}",
              "op": "gte",
              "right": "50"
            },
            {
              "id": "c2",
              "left": "{{step_7.stars}}",
              "op": "gt",
              "right": "0"
            }
          ]
        }
      }
    },
    {
      "id": "step_9",
      "type": "excel",
      "name": "9.生成Excel日报表",
      "config": {
        "file_path": "/tmp/wf-daily-report/daily-report.xlsx",
        "sheet": "舆情日报"
      },
      "actions": [
        {
          "id": "a9_1",
          "type": "create",
          "config": {
            "headers": "数据源,指标,数值,状态"
          }
        },
        {
          "id": "a9_2",
          "type": "write",
          "config": {
            "value": [
              [
                "HackerNews",
                "热榜总数",
                "{{step_4.total}}",
                "正常"
              ],
              [
                "HackerNews",
                "Top10 ID",
                "{{step_4.top_ids}}",
                "-"
              ],
              [
                "GitHub",
                "Stars",
                "{{step_7.stars}}",
                "{{step_7.level}}"
              ],
              [
                "GitHub",
                "Forks",
                "{{step_7.forks}}",
                "-"
              ],
              [
                "GitHub",
                "Open Issues",
                "{{step_7.open_issues}}",
                "-"
              ],
              [
                "综合",
                "活跃度评分",
                "{{step_7.score}}",
                "{{step_8.branch}}"
              ]
            ]
          }
        },
        {
          "id": "a9_3",
          "type": "sort",
          "config": {
            "column": "数值",
            "order": "desc"
          }
        }
      ]
    },
    {
      "id": "step_10",
      "type": "file",
      "name": "10.归档JSON快照",
      "actions": [
        {
          "id": "a10_1",
          "type": "write",
          "config": {
            "path": "/tmp/wf-daily-report/snapshot.json",
            "content": "{\"hn_count\":{{step_4.total}},\"gh_stars\":{{step_7.stars}},\"gh_forks\":{{step_7.forks}},\"score\":{{step_7.score}},\"level\":\"{{step_7.level}}\",\"condition\":\"{{step_8.branch}}\"}"
          }
        }
      ]
    },
    {
      "id": "step_11",
      "type": "word",
      "name": "11.生成Word日报摘要",
      "config": {
        "file_path": "/tmp/wf-daily-report/daily-summary.docx"
      },
      "actions": [
        {
          "id": "a11_1",
          "type": "create",
          "config": {
            "title": "每日智能舆情报告"
          }
        },
        {
          "id": "a11_2",
          "type": "write",
          "config": {
            "value": "📊 数据源汇总\n• HackerNews热榜: {{step_4.total}}条\n• GitHub仓库({{step_7.repo}}): ⭐{{step_7.stars}} 🔱{{step_7.forks}} ⚠️{{step_7.open_issues}}\n\n📈 活跃度评分: {{step_7.score}}分 → {{step_7.level}}\n📋 综合判断: {{step_8.branch}}\n\n报表文件: /tmp/wf-daily-report/daily-report.xlsx\n快照文件: /tmp/wf-daily-report/snapshot.json"
          }
        }
      ]
    },
    {
      "id": "step_12",
      "type": "notify",
      "name": "12.发送日报通知",
      "config": {
        "notify_type": "system",
        "title": "📊 每日舆情报告已生成",
        "body": "HN热榜{{step_4.total}}条 | GitHub活跃度:{{step_7.score}}分({{step_7.level}})\n报表: /tmp/wf-daily-report/daily-report.xlsx\n文档: /tmp/wf-daily-report/daily-summary.docx"
      }
    }
  ]
}