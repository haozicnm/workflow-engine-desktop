{
  "name": "web-monitor-alert",
  "description": "【教学模板 ⑤】多站点健康监控告警 — 多API探测→历史对比→趋势分析→异常判断→日志归档→分级告警。演示 loop 批量探测、file 状态持久化、Excel 日志追加、runCondition 分级通知。",
  "params": {
    "target_url": "https://jsonplaceholder.typicode.com/posts/1",
    "alert_threshold": 3000,
    "notify_title": "站点监控告警"
  },
  "steps": [
    {
      "id": "step_1",
      "type": "shell",
      "name": "1.初始化监控目录",
      "config": {
        "command": "mkdir -p /tmp/wf-monitor 2>/dev/null; echo 'ready'",
        "shell": "auto",
        "timeout_secs": 5
      }
    },
    {
      "id": "step_2",
      "type": "file",
      "name": "2.读取上次监控状态",
      "actions": [
        {
          "id": "a2_1",
          "type": "read",
          "config": {
            "path": "/tmp/wf-monitor/last-state.json"
          }
        }
      ],
      "onError": "ignore"
    },
    {
      "id": "step_3",
      "type": "loop",
      "name": "3.多站点探测",
      "config": {
        "items": "[{\"name\":\"JSONPlaceholder\",\"url\":\"https://jsonplaceholder.typicode.com/posts/1\"},{\"name\":\"GitHub API\",\"url\":\"https://api.github.com\"},{\"name\":\"HTTPBin\",\"url\":\"https://httpbin.org/get\"}]"
      },
      "body_steps": [
        {
          "id": "body_3_1",
          "type": "http",
          "config": {
            "method": "GET",
            "url": "{{__item.url}}",
            "timeout": 10000,
            "connect_timeout": 5000
          }
        },
        {
          "id": "body_3_2",
          "type": "script",
          "config": {
            "script": "let resp_len = body_3_1.body.len();\nlet status = body_3_1.status;\nlet is_ok = status >= 200 && status < 400;\n#{site: __item.name, url: __item.url, status: status, is_ok: is_ok, body_length: resp_len}"
          }
        }
      ]
    },
    {
      "id": "step_4",
      "type": "script",
      "name": "4.汇总分析+趋势对比",
      "config": {
        "script": "let results = step_3.results;\nlet total = results.len();\nlet ok_count = 0;\nlet fail_count = 0;\nlet alert_sites = [];\nfor r in results {\n    if r.is_ok { ok_count += 1; } else { fail_count += 1; alert_sites.push(r.site); }\n}\nlet health_pct = ok_count * 100 / total;\nlet status = if fail_count > 0 { \"🔴异常\" } else { \"🟢全通\" };\nlet summary = [];\nfor r in results {\n    summary.push(r.site + \":\" + (if r.is_ok { \"OK\" } else { \"FAIL\" }));\n}\n#{alert_sites: alert_sites, fail_count: fail_count, health_pct: health_pct, ok_count: ok_count, status: status, summary: summary.join(\", \"), total: total}"
      }
    },
    {
      "id": "step_5",
      "type": "logic",
      "name": "5.异常判断",
      "config": {
        "conditionGroup": {
          "combinator": "or",
          "conditions": [
            {
              "id": "c1",
              "left": "{{step_4.fail_count}}",
              "op": "gt",
              "right": "0"
            },
            {
              "id": "c2",
              "left": "{{step_4.health_pct}}",
              "op": "lt",
              "right": "100"
            }
          ]
        }
      }
    },
    {
      "id": "step_6",
      "type": "file",
      "name": "6.保存本次监控状态",
      "actions": [
        {
          "id": "a6_1",
          "type": "write",
          "config": {
            "path": "/tmp/wf-monitor/last-state.json",
            "content": "{\"ok\":{{step_4.ok_count}},\"fail\":{{step_4.fail_count}},\"health\":{{step_4.health_pct}},\"status\":\"{{step_4.status}}\"}"
          }
        }
      ]
    },
    {
      "id": "step_7",
      "type": "excel",
      "name": "7.追加监控日志到Excel",
      "onError": "ignore",
      "actions": [
        {
          "id": "a7_1",
          "type": "append",
          "config": {
            "value": ["{{step_4.status}}", "{{step_4.ok_count}}", "{{step_4.fail_count}}", "{{step_4.health_pct}}%", "{{step_4.summary}}"]
          }
        }
      ]
    },
    {
      "id": "step_8",
      "type": "notify",
      "name": "8a.异常告警",
      "runCondition": {
        "ref": "step_5",
        "when": "true"
      },
      "config": {
        "notify_type": "system",
        "title": "🚨 站点监控告警",
        "body": "{{step_4.status}}\n正常: {{step_4.ok_count}}/{{step_4.total}} | 异常: {{step_4.fail_count}}/{{step_4.total}}\n健康度: {{step_4.health_pct}}%\n异常站点: {{step_4.alert_sites}}\n日志: /tmp/wf-monitor/monitor-log.xlsx"
      }
    },
    {
      "id": "step_9",
      "type": "notify",
      "name": "8b.正常报告",
      "runCondition": {
        "ref": "step_5",
        "when": "false"
      },
      "config": {
        "notify_type": "system",
        "title": "✅ 站点监控正常",
        "body": "全部{{step_4.total}}个站点正常\n健康度: {{step_4.health_pct}}%"
      }
    }
  ]
}