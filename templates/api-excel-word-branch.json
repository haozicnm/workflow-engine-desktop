{
  "name": "JSON数据 → 条件分流 Word/Excel",
  "description": "Excel读取数据 → 逻辑判断 → Excel写报表 / Word写报告",
  "nodes": [
    {
      "id": "n1",
      "type": "excel_container",
      "label": "数据源",
      "position": { "x": 60, "y": 120 },
      "config": {
        "file_path": "templates/data/订单数据.xlsx",
        "sheet": "Sheet1",
        "actions": [
          { "id": "a1", "type": "read", "label": "读取数据", "config": {} }
        ]
      }
    },
    {
      "id": "n2",
      "type": "logic_container",
      "label": "有数据?",
      "position": { "x": 380, "y": 40 },
      "config": {
        "actions": [
          { "id": "l1", "type": "not_empty", "label": "不为空", "config": {} }
        ]
      }
    },
    {
      "id": "n3",
      "type": "excel_container",
      "label": "订单报表",
      "position": { "x": 700, "y": -60 },
      "config": {
        "file_path": "templates/data/output/订单报表.xlsx",
        "sheet": "已完成订单",
        "actions": [
          { "id": "e1", "type": "filter", "label": "筛选已完成", "config": { "column": "status", "op": "equals", "value": "completed" } },
          { "id": "e2", "type": "write", "label": "写入报表", "config": { "range": "A1" } }
        ]
      }
    },
    {
      "id": "n4",
      "type": "word_container",
      "label": "异常报告",
      "position": { "x": 700, "y": 180 },
      "config": {
        "file_path": "templates/data/output/异常报告.docx",
        "actions": [
          { "id": "wa1", "type": "create", "label": "创建报告", "config": {} },
          { "id": "wa2", "type": "write", "label": "填写详情", "config": {} }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1", "target": "n2", "sourceHandle": "a1_out", "targetHandle": "输入" },
    { "id": "e2", "source": "n2", "target": "n3", "sourceHandle": "true出口", "targetHandle": "e2_in" },
    { "id": "e3", "source": "n1", "target": "n3", "sourceHandle": "a1_out", "targetHandle": "e1_in" },
    { "id": "e4", "source": "n2", "target": "n4", "sourceHandle": "false出口", "targetHandle": "wa2_in" },
    { "id": "e5", "source": "n1", "target": "n4", "sourceHandle": "a1_out", "targetHandle": "wa2_in" }
  ]
}
