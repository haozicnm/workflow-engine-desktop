{
  "name": "JSON数据 → 条件分流 Word/Excel",
  "description": "Excel读取订单数据 → 条件判断金额 → 大额走Word合同，小额走Excel汇总",
  "steps": [
    {
      "id": "step1",
      "type": "excel",
      "label": "订单数据",
      "expanded": true,
      "config": {
        "file_path": "templates/data/订单数据.xlsx",
        "sheet": "Sheet1"
      },
      "actions": [
        {
          "id": "e1",
          "type": "read_cell",
          "params": { "ref": "A1:C20" }
        }
      ]
    },
    {
      "id": "step2",
      "type": "logic",
      "label": "金额 > 10000?",
      "expanded": true,
      "config": {
        "condition": "{{step1.row1.col3}} > 10000"
      },
      "actions": [
        {
          "id": "l1",
          "type": "greater_than",
          "params": { "left": "{{step1.row1.col3}}", "right": 10000 }
        }
      ],
      "thenSteps": [
        {
          "id": "step3",
          "type": "word",
          "label": "大额合同",
          "expanded": true,
          "config": {
            "file_path": "templates/data/output/合同.docx"
          },
          "actions": [
            {
              "id": "w1",
              "type": "write",
              "params": { "text": "合同编号：HT-{{step1.row1.col1}}\n\n甲方：XX公司\n乙方：{{step1.row1.col2}}\n金额：{{step1.row1.col3}}元" }
            },
            {
              "id": "w2",
              "type": "save",
              "params": { "path": "templates/data/output/合同.docx" }
            }
          ]
        }
      ],
      "elseSteps": [
        {
          "id": "step4",
          "type": "excel",
          "label": "小额汇总",
          "expanded": true,
          "config": {
            "file_path": "templates/data/output/小额汇总.xlsx",
            "sheet": "Sheet1"
          },
          "actions": [
            {
              "id": "e2",
              "type": "write_cell",
              "params": { "ref": "A1", "value": "小额订单汇总" }
            },
            {
              "id": "e3",
              "type": "write_cell",
              "params": { "ref": "A2", "value": "{{step1.output}}" }
            },
            {
              "id": "e4",
              "type": "save",
              "params": { "path": "templates/data/output/小额汇总.xlsx" }
            }
          ]
        }
      ]
    }
  ]
}
