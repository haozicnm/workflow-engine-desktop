{
  "name": "Excel数据 → 批量Word通知书",
  "description": "Excel读取员工数据 → Word生成通知书 → 保存文件",
  "steps": [
    {
      "id": "step1",
      "type": "excel",
      "label": "员工数据",
      "expanded": true,
      "config": {
        "file_path": "templates/data/员工名单.xlsx",
        "sheet": "Sheet1"
      },
      "actions": [
        {
          "id": "e1",
          "type": "read_cell",
          "params": { "ref": "A1:D10" }
        }
      ]
    },
    {
      "id": "step2",
      "type": "logic",
      "label": "有数据?",
      "expanded": true,
      "config": {
        "condition": "{{step1.output}} not_empty"
      },
      "actions": [
        {
          "id": "l1",
          "type": "not_empty",
          "params": { "value": "{{step1.output}}" }
        }
      ],
      "thenSteps": [
        {
          "id": "step3",
          "type": "word",
          "label": "生成通知书",
          "expanded": true,
          "config": {
            "file_path": "templates/data/output/通知书.docx"
          },
          "actions": [
            {
              "id": "w1",
              "type": "write",
              "params": { "text": "员工通知书\n\n姓名：{{step1.row1.col1}}\n部门：{{step1.row1.col2}}\n职位：{{step1.row1.col3}}" }
            },
            {
              "id": "w2",
              "type": "save",
              "params": { "path": "templates/data/output/通知书.docx" }
            }
          ]
        }
      ],
      "elseSteps": []
    }
  ]
}
