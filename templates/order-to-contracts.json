{
  "name": "订单逐笔生成合同",
  "description": "Excel读取订单 → cursor游标逐行迭代 → 每行生成Word合同 → 全部完成后通知",
  "steps": [
    {
      "id": "step_excel",
      "type": "excel",
      "label": "读取订单数据",
      "expanded": true,
      "config": {
        "file_path": "templates/data/订单数据.xlsx",
        "sheet": "Sheet1"
      },
      "actions": [
        {
          "id": "a1",
          "type": "read",
          "label": "read",
          "params": {}
        }
      ]
    },
    {
      "id": "step_cursor",
      "type": "cursor",
      "label": "逐笔迭代",
      "expanded": true,
      "config": {
        "items": "{{step_excel.read.data}}",
        "body": [
          {
            "id": "body_word",
            "type": "word",
            "label": "生成合同",
            "config": {
              "action": "write",
              "path": "templates/data/output/contract_{{__index1}}.docx",
              "paragraphs": [
                "=== 销售合同 ===",
                "订单编号：{{__item}}",
                "处理序号：第 {{__index1}} 笔",
                "---"
              ]
            }
          }
        ]
      }
    },
    {
      "id": "step_done",
      "type": "notify",
      "label": "全部完成",
      "config": {
        "notify_type": "system",
        "title": "批次处理完毕",
        "body": "所有订单已生成合同"
      }
    }
  ]
}
