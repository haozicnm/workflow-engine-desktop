{
  "name": "网页内容获取",
  "description": "获取网页 → 提取正文 → 保存为文件",
  "nodes": [
    {
      "id": "n1",
      "type": "http",
      "label": "获取网页",
      "position": { "x": 60, "y": 150 },
      "config": { "url": "https://example.com", "method": "GET", "timeout": 30 }
    },
    {
      "id": "n2",
      "type": "text_template",
      "label": "格式化内容",
      "position": { "x": 380, "y": 150 },
      "config": { "template": "# 网页内容快照\n\n获取时间: {{now}}\n\n内容长度: {{len}} 字符" }
    },
    {
      "id": "n3",
      "type": "file_save",
      "label": "保存快照",
      "position": { "x": 700, "y": 150 },
      "config": { "path": "./output/web_snapshot.md", "format": "text", "encoding": "utf-8" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1", "target": "n2", "sourceHandle": "result", "targetHandle": "data" },
    { "id": "e2", "source": "n2", "target": "n3", "sourceHandle": "result", "targetHandle": "content" }
  ]
}
