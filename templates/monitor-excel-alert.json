{
  "name": "网页监控 → Excel异常报告",
  "description": "浏览器打开状态页 → 提取标题 → 条件判断 → Excel写入报告",
  "steps": [
    {
      "id": "step1",
      "type": "browser",
      "label": "状态监控",
      "expanded": true,
      "config": {
        "browser": "chromium",
        "headless": false,
        "timeout": 30000
      },
      "actions": [
        {
          "id": "a1",
          "type": "navigate",
          "params": { "url": "file:///templates/data/status-page.html" }
        },
        {
          "id": "a2",
          "type": "evaluate",
          "params": { "script": "return document.title" }
        }
      ]
    },
    {
      "id": "step2",
      "type": "logic",
      "label": "包含异常?",
      "expanded": true,
      "config": {
        "condition": "{{step1.output}} contains 异常"
      },
      "actions": [
        {
          "id": "l1",
          "type": "contains",
          "params": { "text": "{{step1.output}}", "keyword": "异常" }
        }
      ],
      "thenSteps": [
        {
          "id": "step3",
          "type": "excel",
          "label": "异常报告",
          "expanded": true,
          "config": {
            "file_path": "templates/data/output/异常报告.xlsx",
            "sheet": "Sheet1"
          },
          "actions": [
            {
              "id": "e1",
              "type": "write_cell",
              "params": { "ref": "A1", "value": "异常状态报告" }
            },
            {
              "id": "e2",
              "type": "write_cell",
              "params": { "ref": "A2", "value": "{{step1.output}}" }
            },
            {
              "id": "e3",
              "type": "save",
              "params": { "path": "templates/data/output/异常报告.xlsx" }
            }
          ]
        }
      ],
      "elseSteps": []
    }
  ]
}
