{
  "name": "Word文档提取 → Excel汇总分析",
  "description": "Word读取合同内容 → 条件判断大额 → Excel写入分析结果",
  "steps": [
    {
      "id": "step1",
      "type": "word",
      "label": "合同文档",
      "expanded": true,
      "config": {
        "file_path": "templates/data/合同.docx"
      },
      "actions": [
        {
          "id": "w1",
          "type": "read",
          "params": {}
        }
      ]
    },
    {
      "id": "step2",
      "type": "logic",
      "label": "含大额条款?",
      "expanded": true,
      "config": {
        "condition": "{{step1.output}} contains 大额"
      },
      "actions": [
        {
          "id": "l1",
          "type": "contains",
          "params": { "text": "{{step1.output}}", "keyword": "大额" }
        }
      ],
      "thenSteps": [
        {
          "id": "step3",
          "type": "excel",
          "label": "大额分析",
          "expanded": true,
          "config": {
            "file_path": "templates/data/output/合同分析.xlsx",
            "sheet": "Sheet1"
          },
          "actions": [
            {
              "id": "e1",
              "type": "write_cell",
              "params": { "ref": "A1", "value": "合同分析结果" }
            },
            {
              "id": "e2",
              "type": "write_cell",
              "params": { "ref": "A2", "value": "包含大额条款" }
            },
            {
              "id": "e3",
              "type": "write_cell",
              "params": { "ref": "B2", "value": "{{step1.output}}" }
            },
            {
              "id": "e4",
              "type": "save",
              "params": { "path": "templates/data/output/合同分析.xlsx" }
            }
          ]
        }
      ],
      "elseSteps": [
        {
          "id": "step4",
          "type": "excel",
          "label": "普通记录",
          "expanded": true,
          "config": {
            "file_path": "templates/data/output/普通合同.xlsx",
            "sheet": "Sheet1"
          },
          "actions": [
            {
              "id": "e5",
              "type": "write_cell",
              "params": { "ref": "A1", "value": "普通合同" }
            },
            {
              "id": "e6",
              "type": "save",
              "params": { "path": "templates/data/output/普通合同.xlsx" }
            }
          ]
        }
      ]
    }
  ]
}
