{
  "name": "Word文档提取 → Excel汇总分析",
  "description": "读取Word文档 → 提取关键数据 → 数据清洗 → 条件分类 → 写入Excel不同Sheet → 通知汇总",
  "nodes": [
    {
      "id": "n1",
      "type": "word_read",
      "label": "读取合同文档",
      "position": { "x": 60, "y": 120 },
      "config": { "path": "templates/data/合同.docx" }
    },
    {
      "id": "n2",
      "type": "regex_extract",
      "label": "提取金额信息",
      "position": { "x": 360, "y": 20 },
      "config": { "pattern": "\\d{1,3}(,\\d{3})*\\.\\d{2}", "action": "extract", "flags": "g" }
    },
    {
      "id": "n3",
      "type": "regex_extract",
      "label": "提取日期信息",
      "position": { "x": 360, "y": 200 },
      "config": { "pattern": "\\d{4}年\\d{1,2}月\\d{1,2}日", "action": "extract", "flags": "g" }
    },
    {
      "id": "n4",
      "type": "text_template",
      "label": "结构化汇总",
      "position": { "x": 660, "y": 120 },
      "config": { "template": "{\"金额\": {{n2.matches}}, \"日期\": {{n3.matches}}, \"文件名\": \"合同.docx\"}" }
    },
    {
      "id": "n5",
      "type": "condition",
      "label": "金额 ≥ 10万?",
      "position": { "x": 960, "y": 20 },
      "config": { "left": "{{n2.matches}}", "op": "contains", "right": "150", "true_next": "n6", "false_next": "n7" }
    },
    {
      "id": "n6",
      "type": "excel_write",
      "label": "写入大额合同",
      "position": { "x": 1260, "y": -60 },
      "config": { "path": "templates/data/output/合同分析_{{now}}.xlsx", "sheet": "大额合同", "data": "{{n4.result}}" }
    },
    {
      "id": "n7",
      "type": "excel_write",
      "label": "写入普通合同",
      "position": { "x": 1260, "y": 200 },
      "config": { "path": "templates/data/output/合同分析_{{now}}.xlsx", "sheet": "普通合同", "data": "{{n4.result}}" }
    },
    {
      "id": "n8",
      "type": "notify",
      "label": "汇总通知",
      "position": { "x": 1560, "y": 80 },
      "config": { "title": "合同分析完成", "message": "合同数据已提取并分类写入Excel\n金额: {{n2.matches}}\n日期: {{n3.matches}}" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1", "target": "n2", "sourceHandle": "content", "targetHandle": "input" },
    { "id": "e2", "source": "n1", "target": "n3", "sourceHandle": "content", "targetHandle": "input" },
    { "id": "e3", "source": "n2", "target": "n4", "sourceHandle": "matches", "targetHandle": "data" },
    { "id": "e4", "source": "n3", "target": "n4", "sourceHandle": "matches", "targetHandle": "data" },
    { "id": "e5", "source": "n2", "target": "n5", "sourceHandle": "matches", "targetHandle": "left" },
    { "id": "e6", "source": "n4", "target": "n6", "sourceHandle": "result", "targetHandle": "data" },
    { "id": "e7", "source": "n4", "target": "n7", "sourceHandle": "result", "targetHandle": "data" },
    { "id": "e8", "source": "n5", "target": "n8", "sourceHandle": "result", "targetHandle": "input" }
  ]
}
