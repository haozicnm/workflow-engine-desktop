{
  "name": "Word文档提取 → Excel汇总分析",
  "description": "Word读取合同内容 → 逻辑判断分类 → Excel写入不同Sheet",
  "nodes": [
    {
      "id": "n1",
      "type": "word_container",
      "label": "合同文档",
      "position": { "x": 60, "y": 120 },
      "config": {
        "file_path": "templates/data/合同.docx",
        "actions": [
          { "id": "wa1", "type": "read", "label": "读取内容", "config": {} }
        ]
      }
    },
    {
      "id": "n2",
      "type": "logic_container",
      "label": "含大额合同?",
      "position": { "x": 380, "y": 120 },
      "config": {
        "actions": [
          { "id": "l1", "type": "contains", "label": "包含150", "config": { "right": "150" } }
        ]
      }
    },
    {
      "id": "n3",
      "type": "excel_container",
      "label": "合同分析",
      "position": { "x": 700, "y": 40 },
      "config": {
        "file_path": "templates/data/output/合同分析.xlsx",
        "sheet": "Sheet1",
        "actions": [
          { "id": "e1", "type": "write", "label": "写入大额Sheet", "config": { "range": "大额合同!A1" } },
          { "id": "e2", "type": "write", "label": "写入普通Sheet", "config": { "range": "普通合同!A1" } }
        ]
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1", "target": "n2", "sourceHandle": "wa1_out", "targetHandle": "输入" },
    { "id": "e2", "source": "n2", "target": "n3", "sourceHandle": "true出口", "targetHandle": "e1_in" },
    { "id": "e3", "source": "n2", "target": "n3", "sourceHandle": "false出口", "targetHandle": "e2_in" },
    { "id": "e4", "source": "n1", "target": "n3", "sourceHandle": "wa1_out", "targetHandle": "e1_in" },
    { "id": "e5", "source": "n1", "target": "n3", "sourceHandle": "wa1_out", "targetHandle": "e2_in" }
  ]
}
