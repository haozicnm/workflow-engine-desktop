{
  "name": "API数据采集",
  "description": "调用 HTTP API → 解析 JSON → 保存到本地文件",
  "nodes": [
    {
      "id": "n1",
      "type": "http",
      "label": "获取API数据",
      "position": { "x": 60, "y": 120 },
      "config": { "url": "https://jsonplaceholder.typicode.com/users", "method": "GET", "timeout": 30 }
    },
    {
      "id": "n2",
      "type": "json_parse",
      "label": "提取关键字段",
      "position": { "x": 380, "y": 120 },
      "config": { "expression": "$.[*].name", "target_field": "names" }
    },
    {
      "id": "n3",
      "type": "file_save",
      "label": "保存结果",
      "position": { "x": 700, "y": 120 },
      "config": { "path": "./output/api_result.json", "format": "json", "encoding": "utf-8" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1", "target": "n2", "sourceHandle": "result", "targetHandle": "input" },
    { "id": "e2", "source": "n2", "target": "n3", "sourceHandle": "result", "targetHandle": "content" }
  ]
}
