{
  "name": "网页监控 → 条件分流报告",
  "description": "浏览器打开状态页 → 提取文本 → 条件判断「是否异常」→ 异常走Excel错误日志 / 正常走Word状态报告",
  "steps": [
    {
      "id": "step_browser",
      "type": "browser",
      "label": "打开监控页",
      "expanded": true,
      "config": {
        "browser": "chromium",
        "headless": false,
        "timeout": 30000
      },
      "actions": [
        {
          "id": "b1",
          "type": "navigate",
          "label": "navigate",
          "params": { "url": "file:///templates/data/status-page.html" }
        },
        {
          "id": "b2",
          "type": "evaluate",
          "label": "evaluate",
          "params": { "script": "return document.title + ' | ' + document.body.innerText" }
        }
      ]
    },
    {
      "id": "step_logic",
      "type": "logic",
      "label": "是否异常?",
      "expanded": true,
      "config": {
        "value": "{{step_browser.b2}}",
        "true_next": "step_error",
        "false_next": "step_normal"
      },
      "conditionGroup": {
        "combinator": "or",
        "conditions": [
          { "id": "c1", "left": "{{step_browser.b2}}", "op": "contains", "right": "异常" },
          { "id": "c2", "left": "{{step_browser.b2}}", "op": "contains", "right": "error" }
        ]
      }
    },
    {
      "id": "step_error",
      "type": "excel",
      "label": "异常报告",
      "expanded": true,
      "runCondition": { "ref": "step_logic", "when": "true" },
      "config": {
        "file_path": "templates/data/output/异常报告.xlsx",
        "sheet": "Sheet1"
      },
      "actions": [
        {
          "id": "e1",
          "type": "create",
          "label": "create",
          "params": { "headers": "时间,状态,详情" }
        },
        {
          "id": "e2",
          "type": "append",
          "label": "append",
          "params": { "value": [["error", "{{step_browser.b2}}"]] }
        }
      ]
    },
    {
      "id": "step_error_notify",
      "type": "notify",
      "label": "异常通知",
      "runCondition": { "ref": "step_logic", "when": "true" },
      "config": {
        "notify_type": "system",
        "title": "⚠️ 系统异常",
        "body": "监控发现异常，已写入报告"
      }
    },
    {
      "id": "step_normal",
      "type": "word",
      "label": "正常报告",
      "runCondition": { "ref": "step_logic", "when": "false" },
      "config": {
        "file_path": "templates/data/output/状态报告.docx"
      },
      "actions": [
        {
          "id": "w1",
          "type": "create",
          "label": "create",
          "params": { "title": "系统状态报告" }
        },
        {
          "id": "w2",
          "type": "write",
          "label": "write",
          "params": { "value": "监控时间: now\n状态: 正常\n页面内容: {{step_browser.b2}}" }
        }
      ]
    }
  ]
}
