{
    "productName":  "Workflow Engine",
    "version": "9.0.4",
    "identifier":  "com.workflow-engine.desktop",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "Workflow Engine",
                                    "width":  1200,
                                    "height":  800,
                                    "minWidth":  960,
                                    "minHeight":  600,
                                    "resizable":  true,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http: https: ws: wss: tauri: ipc: asset: https://asset.localhost; img-src 'self' data: https: asset: https://asset.localhost; font-src 'self' data:"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "appimage",
                                   "deb",
                                   "nsis"
                               ],
                   "linux":  {
                                 "appimage":  {
                                                  "bundleMediaFramework":  true
                                              },
                                 "deb":  {
                                             "depends":  [
                                                             "libwebkit2gtk-4.1-0",
                                                             "libgtk-3-0",
                                                             "libssl3",
                                                             "libsoup-3.0-0",
                                                             "libjavascriptcoregtk-4.1-0"
                                                         ]
                                         }
                             },
                   "windows":  {
                                   "webviewInstallMode":  {
                                                              "type":  "downloadBootstrapper"
                                                          }
                               },
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "resources":  {
                                     "sidecars/*":  "sidecars/",
                                     "templates/**/*":  "templates/"
                                 }
               },
    "plugins":  {

                }
}
