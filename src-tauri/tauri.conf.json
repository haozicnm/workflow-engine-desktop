{
  "productName": "Workflow Engine",
      "version": "3.4.0",
  "identifier": "com.workflow-engine.desktop",
  "build": {
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix ./src run dev",
    "beforeBuildCommand": "npm --prefix ../src run build"
  },
  "app": {
    "windows": [
      {
        "title": "Workflow Engine",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecars/*": "sidecars/",
      "python-runtime/wheels/**/*": "wheels/",
      "python-runtime/playwright-browsers/**/*": "playwright-browsers/"
    }
  },
  "plugins": {}
}
