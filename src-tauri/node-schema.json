{
  "$schema": "node-schema.json",
  "version": "8.1",
  "description": "Workflow Engine node registry — single source of truth for Rust backend and Vue frontend",
  "nodes": [
    {
      "type": "http",
      "label": "HTTP 请求",
      "category": "core",
      "icon": "globe",
      "is_container": false,
      "desc": "发送 HTTP 请求，支持 GET/POST/PUT/DELETE",
      "inputs": [],
      "outputs": [
        {
          "name": "status",
          "data_type": "number",
          "desc": "HTTP 状态码"
        },
        {
          "name": "body",
          "data_type": "json",
          "desc": "响应体"
        },
        {
          "name": "headers",
          "data_type": "json",
          "desc": "响应头"
        }
      ]
    },
    {
      "type": "script",
      "label": "脚本",
      "category": "core",
      "icon": "code",
      "is_container": false,
      "desc": "执行 Rhai 脚本，支持变量读写和复杂逻辑",
      "inputs": [],
      "outputs": [
        {
          "name": "result",
          "data_type": "json",
          "desc": "脚本返回值"
        }
      ]
    },
    {
      "type": "condition",
      "label": "条件判断",
      "category": "core",
      "icon": "git-branch",
      "is_container": false,
      "desc": "根据条件表达式结果选择执行分支",
      "inputs": [],
      "outputs": [
        {
          "name": "branch",
          "data_type": "text",
          "desc": "分支名 (true/false)"
        },
        {
          "name": "result",
          "data_type": "bool",
          "desc": "条件布尔值"
        }
      ]
    },
    {
      "type": "shell",
      "label": "Shell",
      "category": "core",
      "icon": "terminal",
      "is_container": false,
      "desc": "执行系统命令（bash/powershell/cmd）",
      "inputs": [],
      "outputs": [
        {
          "name": "stdout",
          "data_type": "text",
          "desc": "标准输出"
        },
        {
          "name": "stderr",
          "data_type": "text",
          "desc": "标准错误"
        },
        {
          "name": "exit_code",
          "data_type": "number",
          "desc": "退出码"
        }
      ]
    },
    {
      "type": "delay",
      "label": "延迟",
      "category": "core",
      "icon": "clock",
      "is_container": false,
      "desc": "暂停执行指定毫秒",
      "inputs": [],
      "outputs": []
    },
    {
      "type": "approval",
      "label": "审批",
      "category": "core",
      "icon": "check-circle",
      "is_container": false,
      "desc": "暂停执行等待人工审批，recommended 支持变量引用（如 {{step_check.branch}}）",
      "inputs": [],
      "outputs": [
        {
          "name": "approved",
          "data_type": "bool",
          "desc": "是否通过"
        },
        {
          "name": "comment",
          "data_type": "text",
          "desc": "审批意见"
        }
      ],
      "params": {
        "title": "审批标题",
        "message": "审批消息，支持 {{step_x.field}} 变量",
        "options": "逗号分隔选项（默认：同意,拒绝）",
        "recommended": "推荐选项，支持 {{step_x.branch}} 从条件节点读取",
        "require_review": "true=人工审批（默认）, false=自动用 recommended 决策",
        "timeout": "超时秒数（默认 300）",
        "timeout_action": "超时动作：recommended/reject/approve",
        "timeout_behavior": "auto=超时自动（默认）, manual=永不过期",
        "data_source": "上游步骤 ID，用于 item 上下文"
      }
    },
    {
      "type": "web_scrape",
      "label": "网页抓取",
      "category": "data",
      "icon": "globe",
      "is_container": false,
      "desc": "提取网页内容（支持单页/批量/url_pattern/重试/限速/Excel输出）",
      "inputs": [],
      "outputs": [
        {
          "name": "title",
          "data_type": "text",
          "desc": "页面标题"
        },
        {
          "name": "text",
          "data_type": "text",
          "desc": "纯文本内容"
        },
        {
          "name": "links",
          "data_type": "array",
          "desc": "链接列表"
        }
      ],
      "params": {
        "url": "单个 URL（与 urls/url_pattern 三选一）",
        "urls": "URL 数组，批量抓取",
        "url_pattern": "URL 模式，如 https://site.com/page/{{1..10}}",
        "extract": "提取规则数组 [{selector, fields}]",
        "retry": "每 URL 最大重试次数（默认 0）",
        "retry_delay_ms": "重试间隔毫秒（默认 1000）",
        "delay_between_ms": "URL 间延迟毫秒（默认 0，防封）",
        "fail_fast": "单个失败是否中止全部（默认 false）",
        "excel_output": "结果输出到 Excel 文件路径"
      }
    },
