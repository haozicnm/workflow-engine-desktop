{
  "$schema": "node-schema.json",
  "version": "8.0",
  "description": "Workflow Engine node registry — single source of truth for Rust backend and Vue frontend",
  "nodes": [
    { "type": "http",               "label": "HTTP 请求",      "category": "core",     "icon": "globe",       "is_container": false, "desc": "发送 HTTP 请求，支持 GET/POST/PUT/DELETE" },
    { "type": "script",             "label": "脚本",            "category": "core",     "icon": "code",        "is_container": false, "desc": "执行 Rhai 脚本，支持变量读写和复杂逻辑" },
    { "type": "condition",          "label": "条件判断",        "category": "core",     "icon": "git-branch",  "is_container": false, "desc": "根据条件表达式结果选择执行分支" },
    { "type": "shell",              "label": "Shell",           "category": "core",     "icon": "terminal",    "is_container": false, "desc": "执行系统命令（bash/powershell/cmd）" },
    { "type": "notify",             "label": "通知",            "category": "core",     "icon": "bell",        "is_container": false, "desc": "发送系统通知或消息到指定渠道" },
    { "type": "delay",              "label": "延迟",            "category": "core",     "icon": "clock",       "is_container": false, "desc": "暂停执行指定毫秒" },
    { "type": "approval",           "label": "审批",            "category": "core",     "icon": "check-circle","is_container": false, "desc": "暂停执行等待人工审批" },
    { "type": "web_scrape",         "label": "网页抓取",        "category": "data",     "icon": "globe",       "is_container": false, "desc": "提取网页内容" },
    { "type": "json_parse",         "label": "JSON 解析",       "category": "data",     "icon": "braces",      "is_container": false, "desc": "用点号路径提取 JSON 字段" },
    { "type": "text_template",      "label": "文本拼接",        "category": "data",     "icon": "type",        "is_container": false, "desc": "使用 {{变量}} 占位符模板替换" },
    { "type": "data_set",           "label": "设置变量",        "category": "data",     "icon": "database",    "is_container": false, "desc": "写入或覆盖上下文变量" },
    { "type": "data_get",           "label": "读取变量",        "category": "data",     "icon": "database",    "is_container": false, "desc": "从上下文读取指定变量的值" },
    { "type": "data_length",        "label": "获取长度",        "category": "data",     "icon": "hash",        "is_container": false, "desc": "获取字符串、数组、对象的长度" },
    { "type": "data_default",       "label": "默认值",          "category": "data",     "icon": "shield",      "is_container": false, "desc": "变量为空时设置默认值" },
    { "type": "data_merge",         "label": "合并变量",        "category": "data",     "icon": "git-merge",   "is_container": false, "desc": "将源对象合并到目标对象" },
    { "type": "file_read",          "label": "读取文件",        "category": "file",     "icon": "file-text",   "is_container": false, "desc": "读取文件内容" },
    { "type": "file_write",         "label": "写入文件",        "category": "file",     "icon": "file-plus",   "is_container": false, "desc": "写入内容到文件" },
    { "type": "file_list",          "label": "列出文件",        "category": "file",     "icon": "folder",      "is_container": false, "desc": "列出目录内容" },
    { "type": "file_delete",        "label": "删除文件",        "category": "file",     "icon": "trash-2",     "is_container": false, "desc": "删除文件或目录" },
    { "type": "file_append",        "label": "追加文件",        "category": "file",     "icon": "file-plus",   "is_container": false, "desc": "追加内容到文件末尾" },
    { "type": "file_exists",        "label": "文件存在检查",    "category": "file",     "icon": "search",      "is_container": false, "desc": "检查文件或目录是否存在" },
    { "type": "file_mkdir",         "label": "创建目录",        "category": "file",     "icon": "folder-plus", "is_container": false, "desc": "创建目录（含父目录）" },
    { "type": "file_copy",          "label": "复制文件",        "category": "file",     "icon": "copy",        "is_container": false, "desc": "复制文件或目录" },
    { "type": "file_move",          "label": "移动文件",        "category": "file",     "icon": "move",        "is_container": false, "desc": "移动/重命名文件或目录" },
    { "type": "file_glob",          "label": "通配符查找",      "category": "file",     "icon": "search",      "is_container": false, "desc": "用通配符模式搜索文件" },
    { "type": "file_checksum",      "label": "文件校验",        "category": "file",     "icon": "shield-check","is_container": false, "desc": "计算文件 MD5/SHA256 校验和" },
    { "type": "clipboard_read",     "label": "读取剪贴板",      "category": "system",   "icon": "clipboard",   "is_container": false, "desc": "读取系统剪贴板内容" },
    { "type": "clipboard_write",    "label": "写入剪贴板",      "category": "system",   "icon": "clipboard",   "is_container": false, "desc": "写入内容到系统剪贴板" },
    { "type": "clipboard",          "label": "剪贴板容器",      "category": "system",   "icon": "clipboard",   "is_container": true,  "desc": "剪贴板读写容器" },
    { "type": "regex_extract",      "label": "正则提取",        "category": "data",     "icon": "regex",       "is_container": false, "desc": "用正则表达式提取文本" },
    { "type": "regex_replace",      "label": "正则替换",        "category": "data",     "icon": "regex",       "is_container": false, "desc": "用正则表达式替换文本" },
    { "type": "regex_match",        "label": "正则匹配",        "category": "data",     "icon": "regex",       "is_container": false, "desc": "测试正则表达式是否匹配" },
    { "type": "array_filter",       "label": "数组过滤",        "category": "data",     "icon": "filter",      "is_container": false, "desc": "按条件过滤数组元素" },
    { "type": "array_sort",         "label": "数组排序",        "category": "data",     "icon": "arrow-up-down","is_container": false, "desc": "对数组元素排序" },
    { "type": "array_dedup",        "label": "数组去重",        "category": "data",     "icon": "list",        "is_container": false, "desc": "移除数组中的重复元素" },
    { "type": "array_paginate",     "label": "数组分页",        "category": "data",     "icon": "pagination",  "is_container": false, "desc": "对数组进行分页" },
    { "type": "array_map",          "label": "数组映射",        "category": "data",     "icon": "map",         "is_container": false, "desc": "对数组每个元素执行操作" },
    { "type": "array_join",         "label": "数组连接",        "category": "data",     "icon": "link",        "is_container": false, "desc": "将数组元素连接为字符串" },
    { "type": "array_reduce",       "label": "数组归约",        "category": "data",     "icon": "sigma",       "is_container": false, "desc": "对数组元素执行累积操作" },
    { "type": "convert_to_text",    "label": "转文本",          "category": "convert",  "icon": "type",        "is_container": false, "desc": "将值转换为文本格式" },
    { "type": "convert_to_number",  "label": "转数字",          "category": "convert",  "icon": "hash",        "is_container": false, "desc": "将值转换为数字格式" },
    { "type": "convert_to_json",    "label": "转 JSON",         "category": "convert",  "icon": "braces",      "is_container": false, "desc": "将值转换为 JSON 格式" },
    { "type": "convert_to_csv",     "label": "转 CSV",          "category": "convert",  "icon": "file-spreadsheet","is_container": false, "desc": "将值转换为 CSV 格式" },
    { "type": "convert_to_html",    "label": "转 HTML",         "category": "convert",  "icon": "code",        "is_container": false, "desc": "将值转换为 HTML 格式" },
    { "type": "convert_to_base64",  "label": "转 Base64",       "category": "convert",  "icon": "binary",      "is_container": false, "desc": "将值转换为 Base64 编码" },
    { "type": "loop",               "label": "循环",            "category": "flow",     "icon": "repeat",      "is_container": true,  "desc": "遍历数组，对每个元素执行子步骤" },
    { "type": "while",              "label": "While 循环",      "category": "flow",     "icon": "refresh-cw",  "is_container": true,  "desc": "条件循环，满足条件时重复执行子步骤" },
    { "type": "cursor",             "label": "游标迭代",        "category": "flow",     "icon": "move-right",  "is_container": true,  "desc": "一次处理一项，跨次持久化游标" },
    { "type": "parallel",           "label": "并行执行",        "category": "flow",     "icon": "layout-panel-top","is_container": false,"desc": "并行执行多个子步骤" },
    { "type": "map",                "label": "Map 映射",        "category": "flow",     "icon": "map-pin",     "is_container": false, "desc": "对每个输入元素应用映射函数" },
    { "type": "sub_workflow",       "label": "子工作流",        "category": "flow",     "icon": "workflow",    "is_container": false, "desc": "调用另一个工作流作为子流程" },
    { "type": "mouse_keyboard",     "label": "键鼠操作",        "category": "desktop",  "icon": "mouse-pointer-click","is_container": false, "desc": "模拟鼠标和键盘操作" },
    { "type": "window",             "label": "窗口管理",        "category": "desktop",  "icon": "monitor",     "is_container": false, "desc": "管理桌面窗口" },
    { "type": "ocr",                "label": "OCR 识别",        "category": "ai",       "icon": "scan-text",   "is_container": false, "desc": "从图片中识别文字" },
    { "type": "recording",          "label": "录制回放",        "category": "desktop",  "icon": "video",       "is_container": false, "desc": "录制和回放桌面操作" },
    { "type": "print",              "label": "打印",            "category": "system",   "icon": "printer",     "is_container": false, "desc": "打印文档或内容" },
    { "type": "browser_pdf",        "label": "浏览器PDF",       "category": "browser",  "icon": "file",        "is_container": false, "desc": "将当前页面生成 PDF 文件" },
    { "type": "browser",            "label": "浏览器容器",      "category": "browser",  "icon": "container",   "is_container": true,  "desc": "在一个浏览器窗口内按顺序执行多个操作" },
    { "type": "excel",              "label": "Excel 容器",      "category": "office",   "icon": "container",   "is_container": true,  "desc": "在一个 Excel 文件内按顺序执行多个操作" },
    { "type": "word",               "label": "Word 容器",       "category": "office",   "icon": "container",   "is_container": true,  "desc": "在一个 Word 文件内按顺序执行多个操作" },
    { "type": "logic",              "label": "逻辑判断",        "category": "flow",     "icon": "git-branch",  "is_container": true,  "desc": "逻辑判断容器，输出 true/false 分支" },
    { "type": "file",               "label": "文件容器",        "category": "file",     "icon": "container",   "is_container": true,  "desc": "在一个目录内按顺序执行多个文件操作" }
  ],
  "categories": {
    "core":    { "label": "核心",     "order": 1 },
    "data":    { "label": "数据",     "order": 2 },
    "file":    { "label": "文件",     "order": 3 },
    "convert": { "label": "转换",     "order": 4 },
    "system":  { "label": "系统",     "order": 5 },
    "flow":    { "label": "流程控制", "order": 6 },
    "browser": { "label": "浏览器",   "order": 7 },
    "office":  { "label": "办公",     "order": 8 },
    "desktop": { "label": "桌面",     "order": 9 },
    "ai":      { "label": "AI",       "order": 10 }
  },
  "container_types": ["browser", "excel", "word", "logic", "file", "clipboard", "cursor", "loop", "while"]
}
