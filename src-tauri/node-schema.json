{
  "$schema": "node-schema.json",
  "version": "8.1",
  "description": "Workflow Engine node registry — single source of truth for Rust backend and Vue frontend",
  "nodes": [
    {
      "type": "http",
      "label": "HTTP 请求",
      "category": "core",
      "icon": "globe",
      "is_container": false,
      "desc": "发送 HTTP 请求，支持 GET/POST/PUT/DELETE",
      "inputs": [],
      "outputs": [
        {
          "name": "status",
          "data_type": "number",
          "desc": "HTTP 状态码"
        },
        {
          "name": "body",
          "data_type": "json",
          "desc": "响应体"
        },
        {
          "name": "headers",
          "data_type": "json",
          "desc": "响应头"
        }
      ],
      "params": [
        {"name": "method", "field_type": "select", "options": ["GET","POST","PUT","DELETE"], "required": true, "default": "GET", "desc": "HTTP 方法", "group": "basic"},
        {"name": "url", "field_type": "string", "required": true, "desc": "请求地址", "group": "basic"},
        {"name": "headers", "field_type": "json", "required": false, "desc": "请求头（JSON 对象）", "group": "basic"},
        {"name": "body", "field_type": "json", "required": false, "desc": "请求体（JSON 对象）", "group": "basic"},
        {"name": "timeout", "field_type": "number", "required": false, "default": 30, "desc": "超时秒数", "group": "advanced"}
      ]
    },
    {
      "type": "script",
      "label": "脚本",
      "category": "core",
      "icon": "code",
      "is_container": false,
      "desc": "执行 Rhai 脚本，支持变量读写和复杂逻辑",
      "inputs": [],
      "outputs": [
        {
          "name": "result",
          "data_type": "json",
          "desc": "脚本返回值"
        }
      ],
      "params": [
        {"name": "script", "field_type": "code", "required": true, "desc": "Rhai 脚本代码", "lang": "rhai", "group": "basic"},
        {"name": "variables", "field_type": "json", "required": false, "desc": "输入变量（JSON 对象）", "group": "basic"}
      ]
    },
    {
      "type": "condition",
      "label": "条件判断",
      "category": "core",
      "icon": "git-branch",
      "is_container": false,
      "desc": "根据条件表达式结果选择执行分支",
      "inputs": [],
      "outputs": [
        {
          "name": "branch",
          "data_type": "text",
          "desc": "分支名 (true/false)"
        },
        {
          "name": "result",
          "data_type": "bool",
          "desc": "条件布尔值"
        }
      ],
      "params": [
        {"name": "mode", "field_type": "select", "options": ["conditionGroup","expression"], "required": true, "default": "conditionGroup", "desc": "条件模式", "group": "basic"},
        {"name": "conditionGroup", "field_type": "json", "required": false, "desc": "条件组（JSON 结构化条件）", "group": "basic"},
        {"name": "expression", "field_type": "string", "required": false, "desc": "条件表达式（表达式模式）", "group": "basic"}
      ]
    },
    {
      "type": "shell",
      "label": "Shell",
      "category": "core",
      "icon": "terminal",
      "is_container": false,
      "desc": "执行系统命令（bash/powershell/cmd）",
      "inputs": [],
      "outputs": [
        {
          "name": "stdout",
          "data_type": "text",
          "desc": "标准输出"
        },
        {
          "name": "stderr",
          "data_type": "text",
          "desc": "标准错误"
        },
        {
          "name": "exit_code",
          "data_type": "number",
          "desc": "退出码"
        }
      ],
      "params": [
        {"name": "command", "field_type": "string", "required": true, "desc": "要执行的命令", "group": "basic"},
        {"name": "shell", "field_type": "select", "options": ["auto","bash","powershell","cmd"], "required": false, "default": "auto", "desc": "Shell 类型", "group": "basic"},
        {"name": "cwd", "field_type": "string", "required": false, "desc": "工作目录", "group": "advanced"},
        {"name": "timeout_secs", "field_type": "number", "required": false, "default": 300, "desc": "超时秒数", "group": "advanced"}
      ]
    },
    {
      "type": "delay",
      "label": "延迟",
      "category": "core",
      "icon": "clock",
      "is_container": false,
      "desc": "暂停执行指定毫秒",
      "inputs": [],
      "outputs": []
    },
    {
      "type": "approval",
      "label": "审批",
      "category": "core",
      "icon": "check-circle",
      "is_container": false,
      "desc": "暂停执行等待人工审批，recommended 支持变量引用（如 {{step_check.branch}}）",
      "inputs": [],
      "outputs": [
        {
          "name": "approved",
          "data_type": "bool",
          "desc": "是否通过"
        },
        {
          "name": "comment",
          "data_type": "text",
          "desc": "审批意见"
        }
      ],
      "params": [
        {"name": "title", "field_type": "string", "required": false, "desc": "审批标题", "group": "basic"},
        {"name": "message", "field_type": "string", "required": false, "desc": "审批消息，支持 {{step_x.field}} 变量", "group": "basic"},
        {"name": "options", "field_type": "string", "required": false, "default": "同意,拒绝", "desc": "逗号分隔选项", "group": "basic"},
        {"name": "recommended", "field_type": "string", "required": false, "desc": "推荐选项，支持 {{step_x.branch}} 从条件节点读取", "group": "basic"},
        {"name": "require_review", "field_type": "boolean", "required": false, "default": true, "desc": "true=人工审批, false=自动用 recommended 决策", "group": "basic"},
        {"name": "timeout", "field_type": "number", "required": false, "default": 300, "desc": "超时秒数", "group": "advanced"},
        {"name": "timeout_action", "field_type": "select", "options": ["recommended","reject","approve"], "required": false, "default": "recommended", "desc": "超时动作", "group": "advanced"},
        {"name": "timeout_behavior", "field_type": "select", "options": ["auto","manual"], "required": false, "default": "auto", "desc": "auto=超时自动, manual=永不过期", "group": "advanced"},
        {"name": "data_source", "field_type": "string", "required": false, "desc": "上游步骤 ID，用于 item 上下文", "group": "advanced"}
      ]
    },
    {
      "type": "web_scrape",
      "label": "网页抓取",
      "category": "data",
      "icon": "globe",
      "is_container": false,
      "desc": "提取网页内容（支持单页/批量/url_pattern/重试/限速/Excel输出）",
      "inputs": [],
      "outputs": [
        {
          "name": "title",
          "data_type": "text",
          "desc": "页面标题"
        },
        {
          "name": "text",
          "data_type": "text",
          "desc": "纯文本内容"
        },
        {
          "name": "links",
          "data_type": "array",
          "desc": "链接列表"
        }
      ],
      "params": [
        {"name": "url", "field_type": "string", "required": false, "desc": "单个 URL（与 urls/url_pattern 三选一）", "group": "basic"},
        {"name": "urls", "field_type": "json", "required": false, "desc": "URL 数组，批量抓取", "group": "basic"},
        {"name": "url_pattern", "field_type": "string", "required": false, "desc": "URL 模式，如 https://site.com/page/{{1..10}}", "group": "basic"},
        {"name": "extract", "field_type": "json", "required": false, "desc": "提取规则数组 [{selector, fields}]", "group": "basic"},
        {"name": "retry", "field_type": "number", "required": false, "default": 0, "desc": "每 URL 最大重试次数", "group": "advanced"},
        {"name": "retry_delay_ms", "field_type": "number", "required": false, "default": 1000, "desc": "重试间隔毫秒", "group": "advanced"},
        {"name": "delay_between_ms", "field_type": "number", "required": false, "default": 0, "desc": "URL 间延迟毫秒（防封）", "group": "advanced"},
        {"name": "fail_fast", "field_type": "boolean", "required": false, "default": false, "desc": "单个失败是否中止全部", "group": "advanced"},
        {"name": "excel_output", "field_type": "file_path", "required": false, "desc": "结果输出到 Excel 文件路径", "group": "advanced"}
      ]
    },
    {
      "type": "data_set",
      "label": "设置变量",
      "category": "data",
      "icon": "database",
      "is_container": false,
      "desc": "写入或覆盖上下文变量",
      "inputs": [],
      "outputs": [
        {
          "name": "value",
          "data_type": "json",
          "desc": "写入的值"
        }
      ]
    },
    {
      "type": "data_get",
      "label": "读取变量",
      "category": "data",
      "icon": "database",
      "is_container": false,
      "desc": "从上下文读取指定变量的值",
      "inputs": [],
      "outputs": [
        {
          "name": "value",
          "data_type": "json",
          "desc": "读取的值"
        }
      ]
    },
    {
      "type": "file_read",
      "label": "读取文件",
      "category": "file",
      "icon": "file-text",
      "is_container": false,
      "desc": "读取文件内容",
      "inputs": [],
      "outputs": [
        {
          "name": "content",
          "data_type": "text",
          "desc": "文件内容"
        },
        {
          "name": "size",
          "data_type": "number",
          "desc": "文件大小(bytes)"
        }
      ],
      "params": [
        {"name": "path", "field_type": "string", "required": true, "desc": "文件路径", "group": "basic"},
        {"name": "encoding", "field_type": "select", "options": ["utf-8","base64"], "required": false, "default": "utf-8", "desc": "编码方式", "group": "advanced"}
      ]
    },
    {
      "type": "file_write",
      "label": "写入文件",
      "category": "file",
      "icon": "file-plus",
      "is_container": false,
      "desc": "写入内容到文件",
      "inputs": [],
      "outputs": [
        {
          "name": "path",
          "data_type": "text",
          "desc": "写入的文件路径"
        }
      ],
      "params": [
        {"name": "path", "field_type": "string", "required": true, "desc": "文件路径", "group": "basic"},
        {"name": "content", "field_type": "text", "required": true, "desc": "写入内容", "group": "basic"},
        {"name": "encoding", "field_type": "select", "options": ["utf-8","base64"], "required": false, "default": "utf-8", "desc": "编码方式", "group": "advanced"},
        {"name": "mode", "field_type": "select", "options": ["overwrite","append"], "required": false, "default": "overwrite", "desc": "写入模式", "group": "advanced"}
      ]
    },
    {
      "type": "file_list",
      "label": "列出文件",
      "category": "file",
      "icon": "folder",
      "is_container": false,
      "desc": "列出目录内容",
      "inputs": [],
      "outputs": [
        {
          "name": "files",
          "data_type": "array",
          "desc": "文件列表"
        },
        {
          "name": "count",
          "data_type": "number",
          "desc": "文件数量"
        }
      ]
    },
    {
      "type": "file_exists",
      "label": "文件存在检查",
      "category": "file",
      "icon": "search",
      "is_container": false,
      "desc": "检查文件或目录是否存在",
      "inputs": [],
      "outputs": [
        {
          "name": "exists",
          "data_type": "bool",
          "desc": "是否存在"
        }
      ]
    },
    {
      "type": "file_checksum",
      "label": "文件校验",
      "category": "file",
      "icon": "shield-check",
      "is_container": false,
      "desc": "计算文件 MD5/SHA256 校验和",
      "inputs": [],
      "outputs": [
        {
          "name": "md5",
          "data_type": "text",
          "desc": "MD5 哈希"
        },
        {
          "name": "sha256",
          "data_type": "text",
          "desc": "SHA256 哈希"
        }
      ]
    },
    {
      "type": "clipboard_read",
      "label": "读取剪贴板",
      "category": "system",
      "icon": "clipboard",
      "is_container": false,
      "desc": "读取系统剪贴板内容",
      "inputs": [],
      "outputs": [
        {
          "name": "text",
          "data_type": "text",
          "desc": "剪贴板文本"
        }
      ]
    },
    {
      "type": "clipboard_write",
      "label": "写入剪贴板",
      "category": "system",
      "icon": "clipboard",
      "is_container": false,
      "desc": "写入内容到系统剪贴板",
      "inputs": [],
      "outputs": []
    },
    {
      "type": "regex",
      "label": "正则处理",
      "category": "data",
      "icon": "regex",
      "is_container": false,
      "desc": "正则表达式处理：提取捕获组或测试匹配（由 mode 参数控制）",
      "inputs": [],
      "outputs": [
        {
          "name": "matches",
          "data_type": "array",
          "desc": "匹配结果数组（extract 模式为捕获组，match 模式为匹配位置）"
        },
        {
          "name": "count",
          "data_type": "number",
          "desc": "匹配数量"
        },
        {
          "name": "is_match",
          "data_type": "bool",
          "desc": "是否有匹配"
        }
      ],
      "params": [
        {"name": "mode", "field_type": "select", "options": ["extract","match"], "required": false, "default": "extract", "desc": "extract=提取捕获组, match=测试匹配", "group": "basic"},
        {"name": "pattern", "field_type": "string", "required": true, "desc": "正则表达式", "group": "basic"},
        {"name": "input", "field_type": "text", "required": true, "desc": "输入文本", "group": "basic"},
        {"name": "global", "field_type": "boolean", "required": false, "default": true, "desc": "是否全局匹配", "group": "advanced"}
      ]
    },
    {
      "type": "loop",
      "label": "循环",
      "category": "flow",
      "icon": "repeat",
      "is_container": true,
      "desc": "遍历数组，对每个元素执行子步骤",
      "inputs": [
        {
          "name": "array",
          "data_type": "array",
          "required": true,
          "desc": "要遍历的数组"
        }
      ],
      "outputs": [
        {
          "name": "results",
          "data_type": "array",
          "desc": "每次迭代的结果数组"
        },
        {
          "name": "count",
          "data_type": "number",
          "desc": "迭代次数"
        }
      ]
    },
    {
      "type": "while",
      "label": "While 循环",
      "category": "flow",
      "icon": "refresh-cw",
      "is_container": true,
      "desc": "条件循环，满足条件时重复执行子步骤",
      "inputs": [],
      "outputs": [
        {
          "name": "iterations",
          "data_type": "number",
          "desc": "迭代次数"
        }
      ]
    },
    {
      "type": "cursor",
      "label": "游标迭代",
      "category": "flow",
      "icon": "move-right",
      "is_container": true,
      "desc": "一次处理一项，跨次持久化游标",
      "inputs": [
        {
          "name": "array",
          "data_type": "array",
          "required": true,
          "desc": "要遍历的数组"
        }
      ],
      "outputs": [
        {
          "name": "current",
          "data_type": "json",
          "desc": "当前项"
        },
        {
          "name": "index",
          "data_type": "number",
          "desc": "当前索引"
        }
      ]
    },
    {
      "type": "parallel",
      "label": "并行执行",
      "category": "flow",
      "icon": "layout-panel-top",
      "is_container": false,
      "desc": "并行执行多个子步骤",
      "inputs": [],
      "outputs": [
        {
          "name": "results",
          "data_type": "array",
          "desc": "各分支结果"
        }
      ]
    },
    {
      "type": "map",
      "label": "Map 映射",
      "category": "flow",
      "icon": "map-pin",
      "is_container": false,
      "desc": "对每个输入元素应用映射函数",
      "inputs": [
        {
          "name": "array",
          "data_type": "array",
          "required": true,
          "desc": "输入数组"
        }
      ],
      "outputs": [
        {
          "name": "result",
          "data_type": "array",
          "desc": "映射结果"
        }
      ]
    },
    {
