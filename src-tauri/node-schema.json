{
  "$schema": "node-schema.json",
  "version": "8.2",
  "description": "Workflow Engine node registry — single source of truth for Rust backend and Vue frontend",
  "nodes": [
    {
      "type": "http",
      "label": "HTTP 请求",
      "category": "core",
      "icon": "globe",
      "is_container": false,
      "desc": "发送 HTTP 请求，支持 GET/POST/PUT/DELETE",
      "inputs": [],
      "outputs": [
        {
          "name": "status",
          "data_type": "number",
          "desc": "HTTP 状态码"
        },
        {
          "name": "body",
          "data_type": "json",
          "desc": "响应体"
        },
        {
          "name": "headers",
          "data_type": "json",
          "desc": "响应头"
        }
      ],
      "params": [
        {
          "name": "method",
          "field_type": "select",
          "options": [
            "GET",
            "POST",
            "PUT",
            "DELETE"
          ],
          "required": true,
          "default": "GET",
          "desc": "HTTP 方法",
          "group": "basic"
        },
        {
          "name": "url",
          "field_type": "string",
          "required": true,
          "desc": "请求地址",
          "group": "basic",
          "validation": {
            "pattern": "^https?://.*",
            "pattern_desc": "必须以 http:// 或 https:// 开头"
          },
          "examples": [
            {
              "desc": "GET 请求",
              "value": "https://api.example.com/data"
            },
            {
              "desc": "带变量引用",
              "value": "https://api.example.com/users/{{step_1.user_id}}"
            }
          ]
        },
        {
          "name": "headers",
          "field_type": "json",
          "required": false,
          "desc": "请求头（JSON 对象）",
          "group": "basic",
          "examples": [
            {
              "desc": "JSON 请求头",
              "value": {
                "Content-Type": "application/json",
                "Authorization": "Bearer {{token}}"
              }
            }
          ]
        },
        {
          "name": "body",
          "field_type": "json",
          "required": false,
          "desc": "请求体（JSON 对象）",
          "group": "basic"
        },
        {
          "name": "timeout",
          "field_type": "number",
          "required": false,
          "default": 30,
          "desc": "超时秒数",
          "group": "advanced",
          "validation": {
            "min": 1,
            "max": 300,
            "desc": "1-300秒"
          }
        }
      ],
      "tags": [
        "network",
        "api",
        "request",
        "web"
      ]
    },
    {
      "type": "script",
      "label": "脚本",
      "category": "core",
      "icon": "code",
      "is_container": false,
      "desc": "执行 Rhai 脚本，支持变量读写和复杂逻辑",
      "inputs": [],
      "outputs": [
        {
          "name": "result",
          "data_type": "json",
          "desc": "脚本返回值"
        }
      ],
      "params": [
        {
          "name": "script",
          "field_type": "code",
          "required": true,
          "desc": "Rhai 脚本代码",
          "lang": "rhai",
          "group": "basic",
          "examples": [
            {
              "desc": "返回变量",
              "value": "step_1.stdout.to_upper()"
            },
            {
              "desc": "条件逻辑",
              "value": "if step_1.status == 200 { step_1.body } else { #{error: \"failed\"} }"
            }
          ]
        },
        {
          "name": "variables",
          "field_type": "json",
          "required": false,
          "desc": "输入变量（JSON 对象）",
          "group": "basic"
        }
      ],
      "tags": [
        "code",
        "logic",
        "rhai",
        "programming"
      ]
    },
    {
      "type": "condition",
      "label": "条件判断",
      "category": "core",
      "icon": "git-branch",
      "is_container": false,
      "desc": "根据条件表达式结果选择执行分支",
      "inputs": [],
      "outputs": [
        {
          "name": "branch",
          "data_type": "text",
          "desc": "分支名 (true/false)"
        },
        {
          "name": "result",
          "data_type": "bool",
          "desc": "条件布尔值"
        }
      ],
      "params": [
        {
          "name": "mode",
          "field_type": "select",
          "options": [
            "conditionGroup",
            "expression"
          ],
          "required": true,
          "default": "conditionGroup",
          "desc": "条件模式",
          "group": "basic"
        },
        {
          "name": "conditionGroup",
          "field_type": "json",
          "required": false,
          "desc": "条件组（JSON 结构化条件）",
          "group": "basic",
          "visible_when": {
            "param": "mode",
            "value": "conditionGroup"
          }
        },
        {
          "name": "expression",
          "field_type": "string",
          "required": false,
          "desc": "条件表达式（表达式模式）",
          "group": "basic",
          "visible_when": {
            "param": "mode",
            "value": "expression"
          },
          "examples": [
            {
              "value": "step_1.status == 200"
            },
            {
              "value": "step_1.body.items.length() > 0"
            }
          ]
        }
      ],
      "tags": [
        "logic",
        "branch",
        "control-flow",
        "if"
      ]
    },
    {
      "type": "shell",
      "label": "Shell",
      "category": "core",
      "icon": "terminal",
      "is_container": false,
      "desc": "执行系统命令（bash/powershell/cmd）",
      "inputs": [],
      "outputs": [
        {
          "name": "stdout",
          "data_type": "text",
          "desc": "标准输出"
        },
        {
          "name": "stderr",
          "data_type": "text",
          "desc": "标准错误"
        },
        {
          "name": "exit_code",
          "data_type": "number",
          "desc": "退出码"
        }
      ],
      "params": [
        {
          "name": "command",
          "field_type": "string",
          "required": true,
          "desc": "要执行的命令",
          "group": "basic",
          "examples": [
            {
              "desc": "列出文件",
              "value": "ls -la /tmp"
            },
            {
              "desc": "PowerShell 命令",
              "value": "Get-Process | Select-Object -First 5"
            }
          ]
        },
        {
          "name": "shell",
          "field_type": "select",
          "options": [
            "auto",
            "bash",
            "powershell",
            "cmd"
          ],
          "required": false,
          "default": "auto",
          "desc": "Shell 类型",
          "group": "basic"
        },
        {
          "name": "cwd",
          "field_type": "string",
          "required": false,
          "desc": "工作目录",
          "group": "advanced"
        },
        {
          "name": "timeout_secs",
          "field_type": "number",
          "required": false,
          "default": 300,
          "desc": "超时秒数",
          "group": "advanced",
          "validation": {
            "min": 1,
            "max": 3600,
            "desc": "1-3600秒"
          }
        }
      ],
      "tags": [
        "command",
        "terminal",
        "system",
        "execute"
      ]
    },
    {
      "type": "delay",
      "label": "延迟",
      "category": "core",
      "icon": "clock",
      "is_container": false,
      "desc": "暂停执行指定毫秒",
      "inputs": [],
      "outputs": [],
      "params": [
        {
          "name": "ms",
          "field_type": "number",
          "required": true,
          "default": 1000,
          "desc": "延迟毫秒数",
          "group": "basic",
          "validation": {
            "min": 0,
            "max": 86400000,
            "desc": "0-86400000毫秒（最多24小时）"
          }
        }
      ],
      "tags": [
        "timing",
        "wait",
        "sleep"
      ]
    },
    {
      "type": "approval",
      "label": "审批",
      "category": "core",
      "icon": "check-circle",
      "is_container": false,
      "desc": "暂停执行等待人工审批，recommended 支持变量引用（如 {{step_check.branch}}）",
      "inputs": [],
      "outputs": [
        {
          "name": "approved",
          "data_type": "bool",
          "desc": "是否通过"
        },
        {
          "name": "comment",
          "data_type": "text",
          "desc": "审批意见"
        }
      ],
      "params": [
        {
          "name": "title",
          "field_type": "string",
          "required": false,
          "desc": "审批标题",
          "group": "basic"
        },
        {
          "name": "message",
          "field_type": "string",
          "required": false,
          "desc": "审批消息，支持 {{step_x.field}} 变量",
          "group": "basic"
        },
        {
          "name": "options",
          "field_type": "string",
          "required": false,
          "default": "同意,拒绝",
          "desc": "逗号分隔选项",
          "group": "basic"
        },
        {
          "name": "recommended",
          "field_type": "string",
          "required": false,
          "desc": "推荐选项，支持 {{step_x.branch}} 从条件节点读取",
          "group": "basic",
          "visible_when": {
            "param": "require_review",
            "value": true
          }
        },
        {
          "name": "require_review",
          "field_type": "boolean",
          "required": false,
          "default": true,
          "desc": "true=人工审批, false=自动用 recommended 决策",
          "group": "basic"
        },
        {
          "name": "timeout",
          "field_type": "number",
          "required": false,
          "default": 300,
          "desc": "超时秒数",
          "group": "advanced",
          "validation": {
            "min": 10,
            "max": 86400,
            "desc": "10秒-24小时"
          }
        },
        {
          "name": "timeout_action",
          "field_type": "select",
          "options": [
            "recommended",
            "reject",
            "approve"
          ],
          "required": false,
          "default": "recommended",
          "desc": "超时动作",
          "group": "advanced",
          "visible_when": {
            "param": "require_review",
            "value": true
          }
        },
        {
          "name": "timeout_behavior",
          "field_type": "select",
          "options": [
            "auto",
            "manual"
          ],
          "required": false,
          "default": "auto",
          "desc": "auto=超时自动, manual=永不过期",
          "group": "advanced"
        },
        {
          "name": "data_source",
          "field_type": "string",
          "required": false,
          "desc": "上游步骤 ID，用于 item 上下文",
          "group": "advanced"
        }
      ],
      "tags": [
        "human",
        "review",
        "decision"
      ]
    },
    {
      "type": "web_scrape",
      "label": "网页抓取",
      "category": "data",
      "icon": "globe",
      "is_container": false,
      "desc": "提取网页内容（支持单页/批量/url_pattern/重试/限速/Excel输出）",
      "inputs": [],
      "outputs": [
        {
          "name": "title",
          "data_type": "text",
          "desc": "页面标题"
        },
        {
          "name": "text",
          "data_type": "text",
          "desc": "纯文本内容"
        },
        {
          "name": "links",
          "data_type": "array",
          "desc": "链接列表"
        }
      ],
      "params": [
        {
          "name": "url",
          "field_type": "string",
          "required": false,
          "desc": "单个 URL（与 urls/url_pattern 三选一）",
          "group": "basic",
          "examples": [
            {
              "value": "https://example.com/page"
            }
          ]
        },
        {
          "name": "urls",
          "field_type": "json",
          "required": false,
          "desc": "URL 数组，批量抓取",
          "group": "basic",
          "visible_when": {
            "param": "url",
            "op": "empty"
          },
          "examples": [
            {
              "value": [
                "https://example.com/page1",
                "https://example.com/page2"
              ]
            }
          ]
        },
        {
          "name": "url_pattern",
          "field_type": "string",
          "required": false,
          "desc": "URL 模式，如 https://site.com/page/{{1..10}}",
          "group": "basic",
          "visible_when": {
            "param": "url",
            "op": "empty"
          },
          "examples": [
            {
              "desc": "批量页码",
              "value": "https://example.com/page/{{1..10}}"
            }
          ]
        },
        {
          "name": "extract",
          "field_type": "json",
          "required": false,
          "desc": "提取规则数组 [{selector, fields}]",
          "group": "basic",
          "examples": [
            {
              "desc": "CSS 选择器提取",
              "value": [
                {
                  "selector": ".article-title",
                  "fields": {
                    "title": "text"
                  }
                },
                {
                  "selector": ".price",
                  "fields": {
                    "price": "text"
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "retry",
          "field_type": "number",
          "required": false,
          "default": 0,
          "desc": "每 URL 最大重试次数",
          "group": "advanced",
          "validation": {
            "min": 0,
            "max": 10,
            "desc": "0-10次"
          }
        },
        {
          "name": "retry_delay_ms",
          "field_type": "number",
          "required": false,
          "default": 1000,
          "desc": "重试间隔毫秒",
          "group": "advanced",
          "validation": {
            "min": 0,
            "max": 60000,
            "desc": "0-60秒"
          }
        },
        {
          "name": "delay_between_ms",
          "field_type": "number",
          "required": false,
          "default": 0,
          "desc": "URL 间延迟毫秒（防封）",
          "group": "advanced",
          "validation": {
            "min": 0,
            "max": 60000,
            "desc": "0-60秒"
          }
        },
        {
          "name": "fail_fast",
          "field_type": "boolean",
          "required": false,
          "default": false,
          "desc": "单个失败是否中止全部",
          "group": "advanced"
        },
        {
          "name": "excel_output",
          "field_type": "file_path",
          "required": false,
          "desc": "结果输出到 Excel 文件路径",
          "group": "advanced"
        }
      ],
      "tags": [
        "web",
        "scrape",
        "extract",
        "data"
      ]
    },
    {
      "type": "data_set",
      "label": "设置变量",
      "category": "data",
      "icon": "database",
      "is_container": false,
      "desc": "写入或覆盖上下文变量",
      "inputs": [],
      "outputs": [
        {
          "name": "value",
          "data_type": "json",
          "desc": "写入的值"
        }
      ],
      "params": [
        {
          "name": "name",
          "field_type": "string",
          "required": true,
          "desc": "变量名",
          "group": "basic",
          "validation": {
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
            "pattern_desc": "变量名：字母/下划线开头，只含字母数字下划线"
          },
          "examples": [
            {
              "value": "user_count"
            }
          ]
        },
        {
          "name": "value",
          "field_type": "json",
          "required": true,
          "desc": "变量值（支持 {{step_x.field}} 引用）",
          "group": "basic",
          "examples": [
            {
              "value": "{{step_1.body.total}}"
            },
            {
              "value": 42
            }
          ]
        }
      ],
      "tags": [
        "variable",
        "storage",
        "write"
      ]
    },
    {
      "type": "data_get",
      "label": "读取变量",
      "category": "data",
      "icon": "database",
      "is_container": false,
      "desc": "从上下文读取指定变量的值",
      "inputs": [],
      "outputs": [
        {
          "name": "value",
          "data_type": "json",
          "desc": "读取的值"
        }
      ],
      "params": [
        {
          "name": "name",
          "field_type": "string",
          "required": true,
          "desc": "变量名",
          "group": "basic",
          "validation": {
            "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
            "pattern_desc": "变量名：字母/下划线开头，只含字母数字下划线"
          }
        }
      ],
      "tags": [
        "variable",
        "storage",
        "read"
      ]
    },
    {
      "type": "file_read",
      "label": "读取文件",
      "category": "file",
      "icon": "file-text",
      "is_container": false,
      "desc": "读取文件内容",
      "inputs": [],
      "outputs": [
        {
          "name": "content",
          "data_type": "text",
          "desc": "文件内容"
        },
        {
          "name": "size",
          "data_type": "number",
          "desc": "文件大小(bytes)"
        }
      ],
      "params": [
        {
          "name": "path",
          "field_type": "string",
          "required": true,
          "desc": "文件路径",
          "group": "basic",
          "validation": {
            "min_length": 1,
            "desc": "非空路径"
          }
        },
        {
          "name": "encoding",
          "field_type": "select",
          "options": [
            "utf-8",
            "base64"
          ],
          "required": false,
          "default": "utf-8",
          "desc": "编码方式",
          "group": "advanced"
        }
      ],
      "tags": [
        "file",
        "read",
        "io"
      ]
    },
    {
      "type": "file_write",
      "label": "写入文件",
      "category": "file",
      "icon": "file-plus",
      "is_container": false,
      "desc": "写入内容到文件",
      "inputs": [],
      "outputs": [
        {
          "name": "path",
          "data_type": "text",
          "desc": "写入的文件路径"
        }
      ],
      "params": [
        {
          "name": "path",
          "field_type": "string",
          "required": true,
          "desc": "文件路径",
          "group": "basic",
          "validation": {
            "min_length": 1,
            "desc": "非空路径"
          }
        },
        {
          "name": "content",
          "field_type": "text",
          "required": true,
          "desc": "写入内容",
          "group": "basic"
        },
        {
          "name": "encoding",
          "field_type": "select",
          "options": [
            "utf-8",
            "base64"
          ],
          "required": false,
          "default": "utf-8",
          "desc": "编码方式",
          "group": "advanced"
        },
        {
          "name": "mode",
          "field_type": "select",
          "options": [
            "overwrite",
            "append"
          ],
          "required": false,
          "default": "overwrite",
          "desc": "写入模式",
          "group": "advanced"
        }
      ],
      "tags": [
        "file",
        "write",
        "io"
      ]
    },
    {
      "type": "file_list",
      "label": "列出文件",
      "category": "file",
      "icon": "folder",
      "is_container": false,
      "desc": "列出目录内容",
      "inputs": [],
      "outputs": [
        {
          "name": "files",
          "data_type": "array",
          "desc": "文件列表"
        },
        {
          "name": "count",
          "data_type": "number",
          "desc": "文件数量"
        }
      ],
      "params": [
        {
          "name": "path",
          "field_type": "string",
          "required": true,
          "desc": "目录路径",
          "group": "basic"
        },
        {
          "name": "recursive",
          "field_type": "boolean",
          "required": false,
          "default": false,
          "desc": "是否递归子目录",
          "group": "basic"
        },
        {
          "name": "filter",
          "field_type": "string",
          "required": false,
          "desc": "文件名通配符过滤（如 *.txt）",
          "group": "basic"
        }
      ],
      "tags": [
        "file",
        "directory",
        "list",
        "io"
      ]
    },
    {
      "type": "file_exists",
      "label": "文件存在检查",
      "category": "file",
      "icon": "search",
      "is_container": false,
      "desc": "检查文件或目录是否存在",
      "inputs": [],
      "outputs": [
        {
          "name": "exists",
          "data_type": "bool",
          "desc": "是否存在"
        }
      ],
      "params": [
        {
          "name": "path",
          "field_type": "string",
          "required": true,
          "desc": "文件或目录路径",
          "group": "basic"
        }
      ],
      "tags": [
        "file",
        "check",
        "io"
      ]
    },
    {
      "type": "file_checksum",
      "label": "文件校验",
      "category": "file",
      "icon": "shield-check",
      "is_container": false,
      "desc": "计算文件 MD5/SHA256 校验和",
      "inputs": [],
      "outputs": [
        {
          "name": "md5",
          "data_type": "text",
          "desc": "MD5 哈希"
        },
        {
          "name": "sha256",
          "data_type": "text",
          "desc": "SHA256 哈希"
        }
      ],
      "params": [
        {
          "name": "path",
          "field_type": "string",
          "required": true,
          "desc": "文件路径",
          "group": "basic"
        }
      ],
      "tags": [
        "file",
        "hash",
        "verify",
        "io"
      ]
    },
    {
      "type": "clipboard_read",
      "label": "读取剪贴板",
      "category": "system",
      "icon": "clipboard",
      "is_container": false,
      "desc": "读取系统剪贴板内容",
      "inputs": [],
      "outputs": [
        {
          "name": "text",
          "data_type": "text",
          "desc": "剪贴板文本"
        }
      ],
      "params": [],
